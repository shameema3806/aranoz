<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Order Details</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/animate.css">
  <link rel="stylesheet" href="/css/owl.carousel.min.css">
  <link rel="stylesheet" href="/css/all.css">
  <link rel="stylesheet" href="/css/flaticon.css">
  <link rel="stylesheet" href="/css/themify-icons.css">
  <link rel="stylesheet" href="/css/magnific-popup.css">
  <link rel="stylesheet" href="/css/slick.css">
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />

  <style>
    .signup-in-link { color: black; margin-right: 8px; text-decoration: none; font-weight: 500; }
    .dropdown { position: relative; display: inline-block; }
    .dropdown-content { display: none; position: absolute; background-color: white; min-width: 160px; box-shadow: 0px 8px 16px rgba(0,0,0,0.2); z-index: 1000; right: 0; }
    .dropdown-content a { color: black; padding: 12px 16px; text-decoration: none; display: block; width: 100%; }
    .dropdown-content a:hover { background-color: #f1f1f1; }
    .dropdown:hover .dropdown-content { display: block; }
    .header { position: relative; z-index: 500; }
    .btn { border: none; font-size: small; }
    footer a { text-decoration: none !important; }
    footer a:hover { text-decoration: underline; }

    * { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; box-sizing: border-box; }
    body { background-color: #f9fdff; margin: 0; padding: 0; }

    .main-content {
      overflow-x: hidden;
      position: relative;
      min-height: 100vh;
      padding-top: 20px;
      padding-bottom: 60px;
    }

    .custom { padding: 2px 33px 30px; }

    .breadcrumb {
      background: none !important;
      padding: 0;
      margin-bottom: 20px;
      margin-left: 20px;
      margin-top: 100px;
    }
    .breadcrumb-item a { color: #2d3436; text-decoration: none; transition: color 0.3s ease; }
    .breadcrumb-item a:hover { color: #ff3368; }
    .breadcrumb-item.active { color: #d50909; }

    .page-title {
      color: #2d3436;
      font-weight: 700;
      font-size: 2rem;
      margin-bottom: 30px;
      text-transform: uppercase;
      letter-spacing: 1px;
      text-align: center;
    }

    /* ── Desktop layout fix: use Bootstrap row properly ── */
    .order-layout {
      display: flex;
      flex-wrap: wrap;
      gap: 0;
      align-items: flex-start;
    }
    .order-left  { flex: 0 0 66.666%; max-width: 66.666%; padding-right: 15px; }
    .order-right { flex: 0 0 33.333%; max-width: 33.333%; padding-left: 15px; }

    @media (max-width: 991px) {
      .order-left, .order-right { flex: 0 0 100%; max-width: 100%; padding: 0; }
    }

    .detail-card {
      background: white;
      border-radius: 20px;
      box-shadow: 0 10px 40px rgba(0,0,0,0.1);
      padding: 30px;
      margin-bottom: 30px;
      transition: all 0.3s ease;
      border: 2px solid transparent;
      position: relative;
      word-wrap: break-word;
      overflow: hidden;
    }
    .detail-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0;
      width: 100%; height: 4px;
      background: linear-gradient(90deg, #ff3368, #ff6b9d);
      transform: scaleX(0);
      transition: transform 0.3s ease;
    }
    .detail-card:hover { transform: translateY(-3px); box-shadow: 0 15px 50px rgba(0,0,0,0.15); border-color: #ff3368; }
    .detail-card:hover::before { transform: scaleX(1); }

    /* Sticky sidebar fix for desktop */
    .sticky-summary {
      position: sticky;
      top: 120px;
    }

    .section-header {
      color: #2d3436;
      font-weight: 700;
      font-size: 1.5rem;
      margin-bottom: 25px;
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .section-header i { color: #ff3368; font-size: 28px; }

    .info-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
      gap: 15px;
      margin-bottom: 20px;
    }
    .info-item {
      background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
      padding: 15px;
      border-radius: 12px;
      text-align: center;
      transition: all 0.3s ease;
      border: 2px solid transparent;
    }
    .info-item:hover { transform: translateY(-2px); box-shadow: 0 5px 15px rgba(0,0,0,0.1); border-color: #ff3368; }
    .info-item strong { color: #2d3436; display: block; margin-bottom: 5px; font-size: 0.95rem; }
    .info-item p { margin: 0; color: #636e72; font-size: 0.9rem; }

    .status-badge {
      padding: 6px 12px;
      border-radius: 20px;
      font-weight: 600;
      font-size: 0.85rem;
      display: inline-block;
    }
    .bg-success { background: linear-gradient(135deg, #28a745, #20c997) !important; color: white !important; }
    .bg-danger  { background: linear-gradient(135deg, #dc3545, #c82333) !important; color: white !important; }
    .bg-warning { background: linear-gradient(135deg, #ffc107, #ffb300) !important; color: #2d3436 !important; }
    .bg-secondary { background: linear-gradient(135deg, #6c757d, #5a6268) !important; color: white !important; }

    /* Timeline */
    .timeline { position: relative; margin: 30px 0; padding-left: 50px; }
    .timeline::before {
      content: '';
      position: absolute;
      top: 0; bottom: 0; left: 15px;
      width: 4px;
      background: linear-gradient(to bottom, #ff3368, #ff6b9d);
      border-radius: 2px;
    }
    .timeline-item { position: relative; margin-bottom: 30px; }
    .timeline-icon {
      position: absolute;
      left: -45px; top: 5px;
      width: 38px; height: 38px;
      border-radius: 50%;
      background: #ff3368;
      display: flex; align-items: center; justify-content: center;
      color: white; font-size: 14px;
      z-index: 1;
      box-shadow: 0 4px 15px rgba(255,51,104,0.4);
      transition: all 0.3s ease;
      border: 3px solid rgba(255,255,255,0.3);
    }
    .timeline-icon.bg-secondary { background: linear-gradient(135deg, #6c757d, #5a6268); }
    .timeline-icon.bg-warning   { background: linear-gradient(135deg, #ffc107, #e0a800); color: #2d3436; }
    .timeline-icon.bg-info      { background: linear-gradient(135deg, #17a2b8, #138496); }
    .timeline-icon.bg-success   { background: linear-gradient(135deg, #28a745, #20c997); }
    .timeline-icon.bg-danger    { background: linear-gradient(135deg, #dc3545, #c82333); }
    .timeline-icon.bg-primary   { background: linear-gradient(135deg, #007bff, #0056b3); }
    .timeline-icon.bg-light     { border: 3px dashed #dee2e6; background: rgba(255,255,255,0.8); color: #6c757d; }
    .timeline-icon.completed    { background: linear-gradient(135deg, #28a745, #20c997) !important; }
    .timeline-icon.current      { box-shadow: 0 0 0 4px rgba(255,193,7,0.6), 0 6px 20px rgba(255,51,104,0.4); }

    .timeline-content {
      background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
      padding: 20px;
      border-radius: 15px;
      border-left: 5px solid #ff3368;
      box-shadow: 0 4px 15px rgba(0,0,0,0.08);
      transition: all 0.3s ease;
    }
    .timeline-content:hover { transform: translateX(5px); }
    .timeline-content.current-step {
      border-left-color: #ffc107 !important;
      background: linear-gradient(135deg, #fff3cd 0%, #ffeaa7 100%);
    }
    .timeline-content h5 { color: #2d3436; margin-bottom: 8px; font-size: 1.1rem; font-weight: 700; }
    .timeline-content p  { color: #636e72; margin: 0 0 6px; font-size: 0.95rem; line-height: 1.6; }

    /* Items */
    .item-card {
      display: flex;
      align-items: center;
      gap: 15px;
      padding: 15px;
      border: 2px solid #dee2e6;
      border-radius: 15px;
      margin-bottom: 12px;
      background: linear-gradient(135deg, #fff5f8 0%, #ffe8f0 100%);
      transition: all 0.3s ease;
    }
    .item-card:hover { transform: translateX(5px); border-color: #ff3368; box-shadow: 0 5px 20px rgba(255,51,104,0.15); }
    .item-image { width: 70px; height: 70px; border-radius: 10px; object-fit: cover; border: 2px solid #ff3368; flex-shrink: 0; }
    .item-card h5 { color: #2d3436; font-weight: 700; margin-bottom: 5px; font-size: 1rem; }
    .quantity-badge {
      background: linear-gradient(135deg, #ff3368, #ff6b9d);
      color: white; padding: 3px 10px; border-radius: 10px;
      font-weight: 600; font-size: 0.8rem; display: inline-block;
    }

    .address-box {
      background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
      padding: 20px; border-radius: 15px; border-left: 4px solid #ff3368;
    }
    .address-box p { color: #636e72; margin-bottom: 8px; line-height: 1.7; }
    .address-box strong { color: #2d3436; font-size: 1rem; }

    .btn-download {
      background: linear-gradient(135deg, #28a745, #20c997);
      color: white; border: none; padding: 12px 20px;
      border-radius: 12px; font-weight: 700; width: 100%; margin-top: 15px;
      transition: all 0.3s ease;
      display: inline-flex; align-items: center; justify-content: center; gap: 8px;
      text-decoration: none; text-transform: uppercase; letter-spacing: 0.5px;
      box-shadow: 0 5px 20px rgba(40,167,69,0.3);
      cursor: pointer;
    }
    .btn-download:hover { transform: translateY(-2px); box-shadow: 0 8px 30px rgba(40,167,69,0.5); color: white; }

    .btn-action {
      border-radius: 12px; font-weight: 700; padding: 12px 20px;
      transition: all 0.3s ease; width: 100%; margin-top: 10px;
      display: inline-flex; align-items: center; justify-content: center; gap: 8px;
      text-transform: uppercase; letter-spacing: 0.5px; border: 2px solid;
      cursor: pointer;
    }
    .btn-action:hover { transform: translateY(-2px); }
    .btn-outline-warning { border-color: #ffc107; color: #ffc107; background: white; }
    .btn-outline-warning:hover { background: #ffc107; color: #2d3436; }
    .btn-outline-danger { border-color: #dc3545; color: #dc3545; background: white; }
    .btn-outline-danger:hover { background: #dc3545; color: white; }

    @media (max-width: 768px) {
      body { padding-top: 80px; }
      .main-content { padding: 15px 10px 40px; }
      .detail-card { padding: 18px; }
      .item-card { flex-direction: column; text-align: center; }
      .item-card .text-end { text-align: center !important; }
      .timeline { padding-left: 38px; }
      .timeline::before { left: 10px; }
      .timeline-icon { left: -33px; width: 32px; height: 32px; font-size: 12px; }
      .info-grid { grid-template-columns: 1fr 1fr; }
      .page-title { font-size: 1.5rem; }
      .section-header { font-size: 1.1rem; }
    }
  </style>
</head>

<body>
  <%- include("../partials/user/header") %>

  <main class="main-content">
    <div class="custom">
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
          <li class="breadcrumb-item">
            <a href="/userProfile" rel="nofollow"><i class="fas fa-user"></i> User Profile</a>
          </li>
          <li class="breadcrumb-item">
            <a href="/orders"><i class="fas fa-shopping-bag"></i> Orders</a>
          </li>
          <li class="breadcrumb-item active" aria-current="page">
            <i class="fas fa-receipt"></i> Order Details
          </li>
        </ol>
      </nav>
    </div>

    <div class="container-fluid px-4">
      <h1 class="page-title"><i class="fas fa-receipt me-2"></i> Order Details</h1>

      <div class="order-layout">

        <!-- ══ LEFT COLUMN ══ -->
        <div class="order-left">

          <!-- Order Info -->
          <div class="detail-card">
            <h2 class="section-header"><i class="fas fa-receipt"></i> Order Details</h2>
            <div class="info-grid">
              <div class="info-item">
                <strong><i class="fas fa-hashtag me-1 text-muted"></i> Order ID</strong>
                <p>#<%= order.orderId %></p>
              </div>
              <div class="info-item">
                <strong><i class="fas fa-calendar me-1 text-muted"></i> Date</strong>
                <p><%= new Date(order.createdOn).toLocaleDateString('en-IN') %></p>
              </div>
              <div class="info-item">
                <strong><i class="fas fa-info-circle me-1 text-muted"></i> Status</strong>
                <p>
                  <span class="status-badge <%=
                    order.status === 'Delivered'     ? 'bg-success' :
                    order.status === 'Cancelled'     ? 'bg-danger'  :
                    order.status === 'Pending'       ? 'bg-warning' :
                    order.status === 'Processing'    ? 'bg-warning' :
                    'bg-secondary'
                  %>"><%= order.status %></span>
                </p>
              </div>
              <div class="info-item">
                <strong><i class="fas fa-rupee-sign me-1 text-muted"></i> Total</strong>
                <p style="font-size:1.1rem; font-weight:700; color:#ff3368;">₹<%= order.finalAmount.toFixed(2) %></p>
              </div>
            </div>
          </div>

          <!-- Timeline -->
          <div class="detail-card">
            <h2 class="section-header"><i class="fas fa-chart-line"></i> Order Timeline</h2>
            <div class="timeline">

              <%
                var statusMap = {
                  'Pending':          { icon: 'fa-clock',         color: 'bg-secondary', label: 'Order Confirmed',    desc: 'Your order has been placed successfully' },
                  'Processing':       { icon: 'fa-spinner',       color: 'bg-warning',   label: 'Order Processing',   desc: 'Your order is being prepared' },
                  'Shipped':          { icon: 'fa-truck',         color: 'bg-info',      label: 'Order Shipped',      desc: 'Your order is on the way' },
                  'Out for Delivery': { icon: 'fa-shipping-fast', color: 'bg-primary',   label: 'Out for Delivery',   desc: 'Your order is out for delivery' },
                  'Delivered':        { icon: 'fa-check-circle',  color: 'bg-success',   label: 'Order Delivered',    desc: 'Your order has been successfully delivered' },
                  'Cancelled':        { icon: 'fa-times',         color: 'bg-danger',    label: 'Order Cancelled',    desc: 'Order has been cancelled' },
                  'Return Request':   { icon: 'fa-undo',          color: 'bg-warning',   label: 'Return Requested',   desc: 'Return request submitted' },
                  'Returned':         { icon: 'fa-undo-alt',      color: 'bg-secondary', label: 'Order Returned',     desc: 'Order has been returned and processed' }
                };

                var history = order.statusHistory;
                if (!history || !Array.isArray(history) || history.length === 0) {
                  history = [{ status: order.status, timestamp: order.createdOn || new Date(), reason: null }];
                }

                var currentIndex = history.findIndex(function(h) { return h.status === order.status; });
              %>

              <% history.forEach(function(event, index) { %>
                <%
                  var map = statusMap[event.status] || { icon: 'fa-question', color: 'bg-secondary', label: event.status, desc: 'Status updated' };
                  var isCurrent   = (index === currentIndex);
                  var isCompleted = (index < currentIndex);
                  var showReason  = (['Cancelled', 'Return Request'].indexOf(event.status) !== -1) && event.reason;
                %>
                <div class="timeline-item">
                  <div class="timeline-icon <%= map.color %> <%= isCompleted ? 'completed' : isCurrent ? 'current' : '' %>">
                    <i class="fas <%= isCompleted ? 'fa-check' : map.icon %>"></i>
                  </div>
                  <div class="timeline-content <%= isCurrent ? 'current-step' : '' %>">
                    <h5><%= map.label %></h5>
                    <p><%= map.desc %></p>
                    <p class="small text-muted mb-0">
                      <i class="fas fa-calendar me-1"></i>
                      <%= new Date(event.timestamp).toLocaleDateString('en-IN') %>
                      <%= new Date(event.timestamp).toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit' }) %>
                    </p>
                    <% if (showReason) { %>
                      <p class="mt-1"><strong>Reason:</strong> <%= event.reason %></p>
                    <% } %>
                  </div>
                </div>
              <% }); %>

              <% if (['Cancelled', 'Return Request', 'Returned'].indexOf(order.status) === -1) { %>
                <%
                  var futureStatuses = ['Processing', 'Shipped', 'Out for Delivery', 'Delivered'].filter(function(s) {
                    return !history.some(function(h) { return h.status === s; });
                  });
                %>
                <% futureStatuses.forEach(function(status) { %>
                  <% var map = statusMap[status]; %>
                  <div class="timeline-item">
                    <div class="timeline-icon bg-light text-muted">
                      <i class="fas fa-arrow-right"></i>
                    </div>
                    <div class="timeline-content text-muted">
                      <h5 class="text-muted"><%= map.label %></h5>
                      <p class="text-muted"><%= map.desc %> (Upcoming)</p>
                    </div>
                  </div>
                <% }); %>
              <% } %>

            </div>
          </div>

          <!-- Order Items -->
          <div class="detail-card">
            <h2 class="section-header"><i class="fas fa-shopping-bag"></i> Order Items (<%= order.orderedItems.length %> items)</h2>
            <% order.orderedItems.forEach(function(item) { %>
              <div class="item-card">
                <img
                  src="<%= item.product && item.product.productImage && item.product.productImage.length > 0 ? '/public/product-images/' + item.product.productImage[0] : '/img/placeholder.jpg' %>"
                  alt="<%= item.product ? item.product.productName : 'Product' %>"
                  class="item-image">
                <div class="flex-grow-1">
                  <h5><%= item.product ? item.product.productName : 'Product' %></h5>
                  <p class="mb-1 small">₹<%= item.price %> each</p>
                  <span class="quantity-badge"><i class="fas fa-cubes me-1"></i>Qty: <%= item.quantity %></span>
                </div>
                <div class="text-end ms-auto">
                  <strong style="color:#ff3368; font-size:1.1rem;">₹<%= (item.price * item.quantity).toFixed(2) %></strong>
                </div>
              </div>
            <% }); %>
          </div>

          <!-- Shipping Address -->
          <div class="detail-card">
            <h2 class="section-header"><i class="fas fa-map-marker-alt"></i> Shipping Address</h2>
            <div class="address-box">
              <p><strong><i class="fas fa-user me-2"></i><%= order.address.name %></strong></p>
              <p><i class="fas fa-home me-2 text-muted"></i><%= order.address.address %>, <%= order.address.city %></p>
              <p><i class="fas fa-map me-2 text-muted"></i><%= order.address.state %>, <%= order.address.pincode %></p>
              <p class="mb-0"><i class="fas fa-phone me-2 text-muted"></i><%= order.address.phone %></p>
            </div>
          </div>

        </div><!-- /order-left -->

        <!-- ══ RIGHT COLUMN ══ -->
        <div class="order-right">
          <div class="detail-card sticky-summary">
            <h2 class="section-header"><i class="fas fa-receipt"></i> Order Summary</h2>
            <div class="info-grid" style="grid-template-columns: 1fr;">
              <div class="info-item">
                <strong>Subtotal</strong>
                <p>₹<%= order.totalPrice.toFixed(2) %></p>
              </div>
              <% if (order.discount > 0) { %>
                <div class="info-item" style="background: linear-gradient(135deg, #d4edda, #c3e6cb);">
                  <strong style="color:#28a745;">Discount</strong>
                  <p style="color:#28a745; font-weight:700;">-₹<%= order.discount.toFixed(2) %></p>
                </div>
              <% } %>
              <div class="info-item">
                <strong>Shipping</strong>
                <p>₹<%= order.shipping || 50 %></p>
              </div>
              <div class="info-item" style="background: linear-gradient(135deg, #fff5f8, #ffe8f0);">
                <strong style="color:#ff3368; font-size:1.1rem;">Total Amount</strong>
                <p style="color:#ff3368; font-weight:700; font-size:1.2rem;">₹<%= order.finalAmount.toFixed(2) %></p>
              </div>
            </div>

            <a href="/orders/<%= order._id %>/invoice" target="_blank" class="btn-download">
              <i class="fas fa-download"></i> Download Invoice
            </a>

            <% if (order.status === 'Delivered') { %>
              <button class="btn-action btn-outline-warning" onclick="requestReturn('<%= order._id %>')">
                <i class="fas fa-undo"></i> Request Return
              </button>
            <% } else if (order.status === 'Pending' || order.status === 'Processing') { %>
              <button class="btn-action btn-outline-danger" onclick="confirmCancel('<%= order._id %>')">
                <i class="fas fa-times"></i> Cancel Order
              </button>
            <% } %>
          </div>
        </div><!-- /order-right -->

      </div><!-- /order-layout -->
    </div>
  </main>

  <%- include("../partials/user/footer") %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

  <script>
    async function confirmCancel(orderId) {
      const { value: reason } = await Swal.fire({
        title: 'Cancel Order?',
        text: 'Please provide a reason for cancellation:',
        input: 'textarea',
        inputPlaceholder: 'Enter reason (optional)...',
        showCancelButton: true,
        confirmButtonColor: '#ff3368',
        cancelButtonColor: '#6c757d',
        confirmButtonText: 'Yes, Cancel Order',
        cancelButtonText: 'No, Keep Order'
      });
      if (reason !== undefined) {
        try {
          const response = await fetch(`/orders/${orderId}/cancel`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ reason: reason || 'No reason provided' })
          });
          const data = await response.json();
          if (data.success) {
            Swal.fire({ icon: 'success', title: 'Cancelled!', text: data.message, confirmButtonColor: '#ff3368' })
              .then(() => location.href = '/orders');
          } else {
            Swal.fire({ icon: 'error', title: 'Error!', text: data.message, confirmButtonColor: '#ff3368' });
          }
        } catch (error) {
          Swal.fire({ icon: 'error', title: 'Error!', text: 'Failed to cancel order.', confirmButtonColor: '#ff3368' });
        }
      }
    }

    async function requestReturn(orderId) {
  const { value: reason } = await Swal.fire({
    title: 'Request Return',
    html: `
      <p style="color:#636e72; margin-bottom:16px;">Select a reason for return:</p>
      <div id="return-reasons" style="display:flex; flex-direction:column; gap:10px; text-align:left;">
        ${[
          'Product is damaged or defective',
          'Wrong item received',
          'Product does not match description',
          'Late delivery no longer needed',
      
        ].map((r, i) => `
          <label style="display:flex; align-items:center; gap:12px; padding:12px 16px; border:2px solid #dee2e6; border-radius:10px; cursor:pointer; transition:all 0.2s;" 
                 onmouseover="this.style.borderColor='#ff3368'; this.style.background='#fff5f8';"
                 onmouseout="if(!document.getElementById('r${i}').checked){this.style.borderColor='#dee2e6'; this.style.background='white';}">
            <input type="radio" id="r${i}" name="returnReason" value="${r}" 
                   style="accent-color:#ff3368; width:18px; height:18px; flex-shrink:0;"
                   onchange="document.querySelectorAll('#return-reasons label').forEach(l=>{ l.style.borderColor='#dee2e6'; l.style.background='white'; }); this.closest('label').style.borderColor='#ff3368'; this.closest('label').style.background='#fff5f8';">
            <span style="font-size:0.95rem; color:#2d3436;">${r}</span>
          </label>
        `).join('')}
      </div>
    `,
    focusConfirm: false,
    showCancelButton: true,
    confirmButtonColor: '#ff3368',
    cancelButtonColor: '#6c757d',
    confirmButtonText: 'Submit Return Request',
    cancelButtonText: 'Cancel',
    preConfirm: () => {
      const selected = document.querySelector('input[name="returnReason"]:checked');
      if (!selected) {
        Swal.showValidationMessage('Please select a reason for return');
        return false;
      }
      return selected.value;
    }
  });

      if (reason) {
        try {
          const response = await fetch(`/orders/${orderId}/return`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ reason: reason })
          });
          const data = await response.json();
          if (data.success) {
            Swal.fire({ icon: 'success', title: 'Submitted!', text: data.message, confirmButtonColor: '#ff3368' })
              .then(() => location.reload());
          } else {
            Swal.fire({ icon: 'error', title: 'Error!', text: data.message, confirmButtonColor: '#ff3368' });
          }
        } catch (error) {
          Swal.fire({ icon: 'error', title: 'Error!', text: 'Failed to submit return request.', confirmButtonColor: '#ff3368' });
        }
      }
    }
  </script>

</body>
</html>
