<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Wallet - Aranoz</title>
    <link href="https://fonts.googleapis.com/css2?family=Nunito+Sans:wght@300;400;600;700;800;900&display=swap"
        rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/sweetalert/2.1.2/sweetalert.min.js"></script>
    <style>
        * {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background-color: #f9fdff;
            margin: 0;
            padding: 0;
            padding-top: 90px !important;
        }

        .wallet-wrapper {
            background-color: #f9fdff;
            min-height: 100vh;
            padding: 40px 0;
        }

        .page-title {
            color: #2d3436;
            font-weight: 700;
            font-size: 2rem;
            margin-bottom: 30px;
            text-transform: uppercase;
            letter-spacing: 1px;
            text-align: center;
        }

        /* Wallet Balance Card */
        .wallet-balance-card {
            background: linear-gradient(135deg, #ff3368 0%, #ff6b9d 100%);
            border-radius: 25px;
            padding: 40px;
            color: white;
            box-shadow: 0 15px 50px rgba(255, 51, 104, 0.4);
            margin-bottom: 30px;
            position: relative;
            overflow: hidden;
        }

        .wallet-balance-card::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -50%;
            width: 400px;
            height: 400px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 50%;
        }

        .wallet-balance-card::after {
            content: '';
            position: absolute;
            bottom: -30%;
            left: -30%;
            width: 300px;
            height: 300px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 50%;
        }

        .balance-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            position: relative;
            z-index: 1;
        }

        .balance-title {
            display: flex;
            align-items: center;
            gap: 15px;
            font-size: 1.3rem;
            font-weight: 700;
        }

        .balance-title i {
            font-size: 2rem;
        }

        .add-money-btn {
            background: white;
            color: #ff3368;
            border: none;
            padding: 12px 25px;
            border-radius: 12px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 8px;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
        }

        .add-money-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
        }

        .balance-amount {
            font-size: 3.5rem;
            font-weight: 800;
            margin: 20px 0;
            position: relative;
            z-index: 1;
        }

        .balance-date {
            font-size: 1rem;
            opacity: 0.9;
            position: relative;
            z-index: 1;
        }

        /* Transaction Section */
        .transaction-section {
            background: white;
            border-radius: 25px;
            padding: 35px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
            margin-bottom: 30px;
        }

        .section-title {
            color: #2d3436;
            font-weight: 700;
            font-size: 1.5rem;
            margin-bottom: 30px;
            padding-bottom: 15px;
            border-bottom: 3px solid #ff3368;
        }

        .transaction-table {
            width: 100%;
        }

        .transaction-header {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            padding: 15px 20px;
            background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
            border-radius: 12px;
            font-weight: 700;
            color: #2d3436;
            margin-bottom: 15px;
        }

        .transaction-row {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            padding: 20px;
            border: 2px solid #f1f3f5;
            border-radius: 12px;
            margin-bottom: 12px;
            transition: all 0.3s ease;
            align-items: center;
        }

        .transaction-row:hover {
            border-color: #ff3368;
            box-shadow: 0 5px 20px rgba(255, 51, 104, 0.15);
            transform: translateX(5px);
        }

        .transaction-date {
            color: #636e72;
            font-weight: 600;
        }

        .transaction-type {
            font-weight: 700;
            padding: 6px 15px;
            border-radius: 20px;
            display: inline-block;
        }

        .transaction-type.credit {
            background: #d4edda;
            color: #28a745;
        }

        .transaction-type.debit {
            background: #f8d7da;
            color: #dc3545;
        }

        .transaction-amount {
            text-align: right;
            font-weight: 700;
            font-size: 1.2rem;
        }

        .transaction-amount.credit {
            color: #28a745;
        }

        .transaction-amount.debit {
            color: #dc3545;
        }

        /* Pagination */
        .pagination-container {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 15px;
            margin-top: 30px;
        }

        .pagination-btn {
            padding: 10px 20px;
            border: 2px solid #ff3368;
            background: white;
            color: #ff3368;
            border-radius: 10px;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .pagination-btn:hover:not(:disabled) {
            background: #ff3368;
            color: white;
            transform: translateY(-2px);
        }

        .pagination-btn:disabled {
            opacity: 0.4;
            cursor: not-allowed;
        }

        .pagination-info {
            color: #636e72;
            font-weight: 600;
        }

        /* Add Money Modal */
        .modal-content {
            border-radius: 25px;
            border: none;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        }

        .modal-header {
            background: linear-gradient(135deg, #ff3368 0%, #ff6b9d 100%);
            color: white;
            border-radius: 25px 25px 0 0;
            padding: 25px 30px;
            border: none;
        }

        .modal-title {
            font-weight: 700;
            font-size: 1.5rem;
        }

        .btn-close {
            filter: brightness(0) invert(1);
        }

        .modal-body {
            padding: 35px;
        }

        .amount-input-group {
            margin-bottom: 25px;
        }

        .amount-input-group label {
            color: #2d3436;
            font-weight: 700;
            margin-bottom: 12px;
            display: block;
            font-size: 1.1rem;
        }

        .amount-input {
            width: 100%;
            padding: 15px 20px;
            border: 2px solid #dee2e6;
            border-radius: 12px;
            font-size: 1.3rem;
            font-weight: 700;
            color: #2d3436;
            transition: all 0.3s ease;
        }

        .amount-input:focus {
            outline: none;
            border-color: #ff3368;
            box-shadow: 0 0 0 4px rgba(255, 51, 104, 0.1);
        }

        .quick-amounts {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 15px;
            margin-bottom: 25px;
        }

        .quick-amount-btn {
            padding: 15px;
            border: 2px solid #dee2e6;
            background: white;
            color: #2d3436;
            border-radius: 12px;
            font-weight: 700;
            font-size: 1.1rem;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .quick-amount-btn:hover {
            border-color: #ff3368;
            background: #fff5f8;
            transform: translateY(-3px);
            box-shadow: 0 5px 15px rgba(255, 51, 104, 0.2);
        }

        .quick-amount-btn.selected {
            border-color: #ff3368;
            background: linear-gradient(135deg, #ff3368 0%, #ff6b9d 100%);
            color: white;
        }

        .wallet-limit-info {
            background: #fff3cd;
            border: 2px solid #ffc107;
            border-radius: 12px;
            padding: 15px;
            margin-bottom: 25px;
            display: flex;
            align-items: center;
            gap: 12px;
            color: #856404;
        }

        .wallet-limit-info i {
            font-size: 1.5rem;
        }

        .submit-btn {
            width: 100%;
            padding: 18px;
            background: linear-gradient(135deg, #ff3368 0%, #ff6b9d 100%);
            color: white;
            border: none;
            border-radius: 12px;
            font-weight: 700;
            font-size: 1.2rem;
            cursor: pointer;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .submit-btn:hover:not(:disabled) {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(255, 51, 104, 0.4);
        }

        .submit-btn:disabled {
            background: #dee2e6;
            cursor: not-allowed;
        }

        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: #636e72;
        }

        .empty-state i {
            font-size: 4rem;
            color: #dee2e6;
            margin-bottom: 20px;
        }

        .empty-state h4 {
            color: #2d3436;
            font-weight: 700;
            margin-bottom: 10px;
        }

        @media (max-width: 768px) {
            .wallet-balance-card {
                padding: 30px 20px;
            }

            .balance-amount {
                font-size: 2.5rem;
            }

            .balance-header {
                flex-direction: column;
                gap: 15px;
            }

            .transaction-header,
            .transaction-row {
                grid-template-columns: 1fr;
                gap: 10px;
            }

            .transaction-amount {
                text-align: left;
            }

            .quick-amounts {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>

<body>
    <%- include('../partials/user/header.ejs') %>

        <div class="wallet-wrapper">
            <div class="container">
                <!-- Breadcrumb -->
                <nav aria-label="breadcrumb" class="mb-4">
                    <ol class="breadcrumb" style="background: none; padding: 0;">
                        <li class="breadcrumb-item"><a href="/" style="color: #2d3436; text-decoration: none;">Home</a>
                        </li>
                        <li class="breadcrumb-item"><a href="/userProfile" style="color: #2d3436; text-decoration: none;"> My Profile</a>

                        <li class="breadcrumb-item active" style="color: #636e72;">My Wallet</li>
                    </ol>
                </nav>

                <h1 class="page-title">My Wallet</h1>

                <!-- Wallet Balance Card -->
                <div class="wallet-balance-card">
                    <div class="balance-header">
                        <div class="balance-title">
                            <i class="fas fa-wallet"></i>
                            Wallet Balance
                        </div>
                        <button class="add-money-btn" data-bs-toggle="modal" data-bs-target="#addMoneyModal">
                            <i class="fas fa-plus"></i>
                            Add Money
                        </button>
                    </div>
                    <div class="balance-amount">
                        ₹<%= walletBalance ? walletBalance.toFixed(2) : '0.00' %>
                    </div>
                    <div class="balance-date">
                        Available balance as of <%= new Date().toLocaleDateString('en-GB') %>
                    </div>
                </div>

                <!-- Transaction History -->
                <div class="transaction-section">
                    <h2 class="section-title">Transaction History</h2>

                    <% if (transactions && transactions.length> 0) { %>
                        <div class="transaction-table">
                            <div class="transaction-header">
                                <div>Date</div>
                                <div>Type</div>
                                <div style="text-align: right;">Amount</div>
                            </div>

                            <% transactions.forEach(transaction=> { %>
                                <div class="transaction-row">
                                    <div class="transaction-date">
                                        <%= new Date(transaction.date).toLocaleDateString('en-GB') %>
                                    </div>
                                    <div>
                                        <span class="transaction-type <%= transaction.type.toLowerCase() %>">
                                            <%= transaction.type %>
                                        </span>
                                        <% if (transaction.description) { %>
                                            <div style="font-size: 0.85rem; color: #636e72; margin-top: 5px;">
                                                <%= transaction.description %>
                                            </div>
                                            <% } %>
                                    </div>
                                    <div class="transaction-amount <%= transaction.type.toLowerCase() %>">
                                        <%= transaction.type==='Credit' ? '+' : '-' %>₹<%=
                                                Math.abs(transaction.amount).toFixed(2) %>
                                    </div>
                                </div>
                                <% }); %>
                        </div>

                        <!-- Pagination -->
                        <div class="pagination-container">
                            <button class="pagination-btn" id="prevBtn" <%=currentPage <=1 ? 'disabled' : '' %>>
                                <i class="fas fa-chevron-left"></i> Prev
                            </button>
                            <span class="pagination-info">
                                <%= currentPage %> of <%= totalPages %>
                            </span>
                            <button class="pagination-btn" id="nextBtn" <%=currentPage>= totalPages ? 'disabled' : ''
                                %>>
                                Next <i class="fas fa-chevron-right"></i>
                            </button>
                        </div>
                        <% } else { %>
                            <div class="empty-state">
                                <i class="fas fa-receipt"></i>
                                <h4>No Transactions Yet</h4>
                                <p>Your transaction history will appear here</p>
                            </div>
                            <% } %>
                </div>
            </div>
        </div>

        <!-- Add Money Modal -->
        <div class="modal fade" id="addMoneyModal" tabindex="-1" aria-labelledby="addMoneyModalLabel"
            aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="addMoneyModalLabel">
                            <i class="fas fa-plus-circle"></i> Add Money to Wallet
                        </h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="wallet-limit-info">
                            <i class="fas fa-info-circle"></i>
                            <div>
                                <strong>Wallet Limit:</strong> Maximum balance allowed is ₹10,000.00
                            </div>
                        </div>

                        <div class="amount-input-group">
                            <label for="amountInput">Amount (₹)</label>
                            <input type="number" class="amount-input" id="amountInput" placeholder="Enter amount"
                                min="1" max="10000">
                        </div>

                        <div class="quick-amounts">
                            <button class="quick-amount-btn" onclick="selectQuickAmount(100)">₹100</button>
                            <button class="quick-amount-btn" onclick="selectQuickAmount(500)">₹500</button>
                            <button class="quick-amount-btn" onclick="selectQuickAmount(1000)">₹1000</button>
                            <button class="quick-amount-btn" onclick="selectQuickAmount(2000)">₹2000</button>
                            <button class="quick-amount-btn" onclick="selectQuickAmount(5000)">₹5000</button>
                            <button class="quick-amount-btn" onclick="selectQuickAmount(10000)">₹10000</button>
                        </div>

                        <button class="submit-btn" onclick="addMoneyToWallet()">
                            <i class="fas fa-check-circle"></i> Add Money
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <%- include('../partials/user/footer.ejs') %>
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
            <script>
                const currentBalance = <%= walletBalance || 0 %>;
                const WALLET_LIMIT = 10000;

                function selectQuickAmount(amount) {
                    // Remove selected class from all buttons
                    document.querySelectorAll('.quick-amount-btn').forEach(btn => {
                        btn.classList.remove('selected');
                    });

                    // Add selected class to clicked button
                    event.target.classList.add('selected');

                    // Set amount in input
                    document.getElementById('amountInput').value = amount;
                }

               
                async function addMoneyToWallet() {
    const amountInput = document.getElementById('amountInput');
    const amount = parseFloat(amountInput.value);

    if (!amount || amount <= 0) {
        swal("Invalid Amount", "Please enter a valid amount", "error");
        return;
    }

    try {
        const response = await fetch('/wallet/add-money', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ amount })
        });

        const data = await response.json();

        if (data.success) {
            const options = {
                key: data.key, // Backend sends process.env.RAZORPAY_KEY_ID
                amount: data.amount * 100, // Razorpay works in paise
                currency: data.currency,
                name: "Aranoz Wallet",
                description: "Wallet Recharge",
                order_id: data.razorpayOrderId, // MATCHES BACKEND: razorpayOrderId
                handler: async function (response) {
                    // This triggers AFTER successful payment
                    const verifyRes = await fetch('/wallet/verify-payment', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            razorpay_order_id: response.razorpay_order_id,
                            razorpay_payment_id: response.razorpay_payment_id,
                            razorpay_signature: response.razorpay_signature,
                            amount: data.amount // Original amount to add to DB
                        })
                    });

                    const verifyData = await verifyRes.json();
                    if (verifyData.success) {
                        swal("Success!", "₹" + amount + " added to your wallet!", "success")
                            .then(() => location.reload());
                    } else {
                        swal("Verification Failed", verifyData.message, "error");
                    }
                },
                prefill: {
                    name: data.customerDetails.name,
                    email: data.customerDetails.email,
                    contact: data.customerDetails.contact
                },
                theme: { color: "#ff3368" }
            };
            const rzp = new Razorpay(options);
            rzp.open();
        } else {
            swal("Error", data.message, "error");
        }
    } catch (error) {
        console.error('Error:', error);
        swal("Error!", "Something went wrong. Please try again.", "error");
    }
}

                // Pagination handlers
                document.getElementById('prevBtn')?.addEventListener('click', () => {
                    const currentPage = <%= currentPage %>;
                    if (currentPage > 1) {
                        window.location.href = `/wallet?page=${currentPage - 1}`;
                    }
                });

                document.getElementById('nextBtn')?.addEventListener('click', () => {
                    const currentPage = <%= currentPage %>;
                    const totalPages = <%= totalPages %>;
                    if (currentPage < totalPages) {
                        window.location.href = `/wallet?page=${currentPage + 1}`;
                    }
                });

                // Clear input when modal closes
                document.getElementById('addMoneyModal').addEventListener('hidden.bs.modal', function () {
                    document.getElementById('amountInput').value = '';
                    document.querySelectorAll('.quick-amount-btn').forEach(btn => {
                        btn.classList.remove('selected');
                    });
                });
            </script>
</body>

</html>