        <script>
            // AJAX Pagination for Featured Offers (No full reload on clicks)
            document.addEventListener('DOMContentLoaded', function () {
                // Attach event listeners to pagination links
                document.addEventListener('click', function (e) {
                    if (e.target.classList.contains('ajax-paginate')) {
                        e.preventDefault();  // Stop default link behavior (no reload)
                        const page = parseInt(e.target.dataset.page);
                        if (page && page !== currentOffersPage) {
                            loadOffersPage(page);
                        }
                    }
                });
            });

            let currentOffersPage = <%= currentOffersPage || 1 %>;  // Initial page from server

            async function loadOffersPage(page) {
                currentOffersPage = page;
                const row = document.getElementById('featuredOffersRow');
                const paginationList = document.getElementById('offersPaginationList');

                row.innerHTML = `
    <div class="col-12 text-center py-4">
      <div class="spinner-border text-primary" role="status">
        <span class="visually-hidden">Loading offers...</span>
      </div>
    </div>
  `;

                try {
                    const res = await fetch(`?offersPage=${page}`);  // Use full URL with current query params
                    if (!res.ok) throw new Error('Failed to load offers');
                    const html = await res.text();  // Get full HTML response (server re-renders section)

                    const parser = new DOMParser();
                    const doc = parser.parseFromString(html, 'text/html');
                    const newRow = doc.querySelector('#featuredOffersRow').innerHTML;
                    row.innerHTML = newRow;

                    const newPagination = doc.querySelector('#offersPaginationList').innerHTML;
                    paginationList.innerHTML = newPagination;


                } catch (error) {
                    console.error('Load offers error:', error);
                    row.innerHTML = `
      <div class="col-12 text-center">
        <p class="text-danger">Error loading offers. Please try again.</p>
      </div>
    `;
                }
            }
        </script>


        <script>
            const updateClock = () => {
                const now = new Date();
                const hours = String(now.getHours()).padStart(2, '0');
                const minutes = String(now.getMinutes()).padStart(2, '0');
                const seconds = String(now.getSeconds()).padStart(2, '0');

                document.getElementById('hours').textContent = hours + 'h';
                document.getElementById('minutes').textContent = minutes + 'm';
                document.getElementById('seconds').textContent = seconds + 's';
            };

            updateClock();
            setInterval(updateClock, 1000);
        </script>