    <!-- Product List Start -->
    <section class="product_list section_padding">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-12">
                    <div class="section_tittle text-center">
                        <h2>Our Products</h2>
                    </div>
                </div>
            </div>
            <div class="row align-items-center justify-content-between">
                <div class="col-lg-12">
                    <div class="best_product_slider owl-carousel">
                        <% if (products && products.length> 0) { %>
                            <% for(let i=0; i < products.length; i++) { %>
                                <div class="single_feature_post_text">
                                    <p>Premium Quality</p>
                                    <h3>
                                        <%= products[i].productName %>
                                    </h3>
                                    <h4>
                                        <% if (products[i].offerPrice) { %>
                                            <span class="original-price"><s>₹<%= products[i].regularPrice.toFixed(2) %>
                                                </s></span>
                                            ₹<%= products[i].offerPrice.toFixed(2) %>
                                                <% } else { %>
                                                    ₹<%= products[i].salePrice.toFixed(2) %>
                                                        <% } %>
                                    </h4>
                                    <div class="product-actions">
                                        <a href="/productDetail?id=<%= products[i]._id %>" class="feature_btn">
                                            Explore Now <i class="fas fa-play"></i>
                                        </a>
                                        <a aria-label="Add to Wishlist" class="action-btn hover-up"
                                            href="/wishlist?id=<%= products[i]._id %>">
                                            <i class="ti-heart"></i>
                                        </a>
                                        <a href="/cart?id=<%= products[i]._id %>" class="action-btn hover-up">
                                            <i class="ti-shopping-cart"></i>
                                        </a>
                                    </div>
                                    <a href="/productDetails?id=<%= products[i]._id %>">
                                        <img src="<%= products[i].productImage && products[i].productImage.length > 0 ? '/public/product-images/' + products[i].productImage[0] : '/img/product/placeholder.jpg' %>"
                                            alt="<%= products[i].productName %>"> </a>
                                </div>
                                <% } %>
                                    <% } else { %>
                                        <p class="text-center">No products available.</p>
                                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <!-- Product List End -->
    <!-- Featured Offers Start -->
    <section class="feature_part padding_top">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <div class="section_tittle text-center">
                        <h2 style="font-size: 29px; font-weight: 900; font-style:inherit ;">SPECIAL OFFERS</h2>
                        <p>Discover our top deals and discounts</p>
                    </div>
                </div>
            </div>
            <div class="row align-items-center justify-content-between" id="featuredOffersRow">
                <% if (featuredOffers && featuredOffers.length> 0) { %>
                    <% featuredOffers.forEach((product, index)=> { %>
                        <% const colClass=index % 2===0 ? 'col-lg-7 col-sm-6' : 'col-lg-5 col-sm-6' ; %>
                            <div class="<%= colClass %>">
                                <div class="single_feature_post_text">
                                    <p>Premium Quality</p>
                                    <h3>
                                        <%= product.productName %>
                                    </h3>
                                    <div class="price-section mb-2">
                                        <% if (product.effectiveOffer && product.effectiveOffer> 0) { %>
                                            <span class="badge bg-danger rounded-pill px-2 py-1 me-2">
                                                -<%= product.effectiveOffer %>% OFF
                                            </span>
                                            <span class="text-success fw-bold fs-5">₹<%= product.effectiveOfferPrice %>
                                            </span>
                                            <br>
                                            <small class="text-muted text-decoration-line-through">₹<%=
                                                    product.salePrice %></small>
                                            <small class="text-danger ms-2"
                                                style="font-size: 0.8rem; font-weight: 600;">
                                                OFF UPTO <%= product.effectiveOffer %>% (₹<%= (product.salePrice -
                                                        parseFloat(product.effectiveOfferPrice)).toFixed(0) %>)
                                            </small>
                                            <% } else { %>
                                                <span class="text-dark fw-bold fs-5">₹<%= product.salePrice %></span>
                                                <% if (product.regularPrice> product.salePrice) { %>
                                                    <small class="text-muted text-decoration-line-through ms-2">₹<%=
                                                            product.regularPrice %></small>
                                                    <% } %>
                                                        <% } %>
                                    </div>
                                    <a href="/productDetail?id=<%= product._id %>" class="feature_btn">Explore Now <i
                                            class="fas fa-play"></i></a>
                                    <% if (product.productImage && product.productImage.length> 0) { %>
                                        <img src="/public/product-images/<%= product.productImage[0] %>"
                                            alt="<%= product.productName %>" class="img-fluid mt-3 rounded shadow">
                                        <% } else { %>
                                            <img src="/img/product/placeholder.jpg" alt="Placeholder"
                                                class="img-fluid mt-3 rounded shadow">
                                            <% } %>
                                </div>
                            </div>
                            <% }) %>
                                <% } else { %>
                                    <!-- Fallback if no offers -->
                                    <div class="col-12 text-center">
                                        <p class="text-muted">No featured offers available right now. Check back soon!
                                        </p>
                                    </div>
                                    <% } %>
            </div>

            <!-- Pagination for Featured Offers (below the row, centered) -->
            <% if (totalOffersPages> 1) { %>
                <nav aria-label="Featured Offers Pagination" class="mt-4">
                    <ul class="pagination justify-content-center" id="offersPaginationList">
                        <!-- Previous -->
                        <li class="page-item <%= currentOffersPage <= 1 ? 'disabled' : '' %>">
                            <a class="page-link ajax-paginate" data-page="<%= currentOffersPage - 1 %>">
                                << /a>
                        </li>

                        <!-- Page Numbers -->
                        <% for(let i=1; i <=totalOffersPages; i++) { %>
                            <li class="page-item <%= i === currentOffersPage ? 'active' : '' %>">
                                <a class="page-link ajax-paginate" data-page="<%= i %>">
                                    <%= i %>
                                </a>
                            </li>
                            <% } %>

                                <!-- Next -->
                                <li class="page-item <%= currentOffersPage >= totalOffersPages ? 'disabled' : '' %>">
                                    <a class="page-link ajax-paginate" data-page="<%= currentOffersPage + 1 %>">></a>
                                </li>
                    </ul>
                </nav>
                <% } %>
        </div>
    </section>

    <!-- Awesome Shop Start -->
