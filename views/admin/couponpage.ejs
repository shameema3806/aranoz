<%- include("../../views/partials/admin/header") %>

<!-- ====================== MAIN CONTENT ====================== -->
<div class="ml-64 pt-12 bg-gray-100 min-h-screen p-6">
  <div class="max-w-full w-full bg-white rounded-xl shadow-lg p-6 space-y-6">

    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 pb-4 border-b-2 border-[#1A5D8C]">
      <h1 class="text-[#154b70] text-2xl font-bold">Coupons</h1>

      <div class="flex items-center gap-3 w-full sm:w-auto">
        <form action="/admin/coupon" method="get" class="flex items-center bg-[#1A5D8C] rounded-md overflow-hidden flex-1 sm:flex-initial">
          <input 
            type="text" 
            name="search" 
            placeholder="Search coupons..."
            value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>"
            class="w-full sm:w-64 px-3 py-2 bg-transparent text-white placeholder-white/70 outline-none text-sm"
          />
          <button type="submit" class="px-3 text-white">
            Search
          </button>
        </form>

        <% if (typeof searchQuery !== 'undefined' && searchQuery) { %>
          <a href="/admin/coupon" class="text-[#1A5D8C] underline text-sm whitespace-nowrap">Clear</a>
        <% } %>

        <button 
          id="showAddCouponPopup" 
          class="bg-[#1A5D8C] hover:bg-[#154b70] text-white font-medium px-4 py-2 rounded-md transition flex items-center gap-2 text-sm whitespace-nowrap">
          <i class="fas fa-plus"></i> Add Coupon
        </button>
      </div>
    </div>

    <!-- Table -->
    <div class="overflow-x-auto">
      <table id="couponTable" class="w-full text-sm min-w-max">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-4 py-3 text-left font-medium text-[#1A5D8C]">S.No.</th>
            <th class="px-4 py-3 text-left font-medium text-[#1A5D8C]">Code</th>
            <th class="px-4 py-3 text-left font-medium text-[#1A5D8C]">Type</th>
            <th class="px-4 py-3 text-left font-medium text-[#1A5D8C]">Value</th>
            <th class="px-4 py-3 text-left font-medium text-[#1A5D8C]">Min Order</th>
            <th class="px-4 py-3 text-left font-medium text-[#1A5D8C]">Max Uses</th>
            <th class="px-4 py-3 text-left font-medium text-[#1A5D8C]">Used</th>
            <th class="px-4 py-3 text-left font-medium text-[#1A5D8C]">Expiry</th>
            <th class="px-4 py-3 text-left font-medium text-[#1A5D8C]">Status</th>
            <th class="px-4 py-3 text-left font-medium text-[#1A5D8C]">Actions</th>
          </tr>
        </thead>
        <tbody id="couponTableBody" class="divide-y divide-gray-200">
          <% if (typeof coupons !== 'undefined' && coupons.length > 0) { %>
            <% coupons.forEach((coupon, index) => { %>
              <% const expiryDate = new Date(coupon.expiryDate); %>
              <% const isExpired = expiryDate < new Date(); %>
              <% const effectiveActive = coupon.isActive && !isExpired; %>
              <tr class="hover:bg-gray-50 transition" data-id="<%= coupon._id %>">
                <td class="px-4 py-3"><%= (currentPage - 1) * itemsPerPage + index + 1 %></td>
                <td class="px-4 py-3 font-medium"><%= coupon.code %></td>
                <td class="px-4 py-3">
                  <span class="inline-block px-2 py-1 text-xs font-medium rounded-full bg-blue-100 text-blue-800">
                    <%= coupon.discountType %>
                  </span>
                </td>
                <td class="px-4 py-3"><%= coupon.discountValue %> <%= coupon.discountType === 'percentage' ? '%' : '$' %></td>
                <td class="px-4 py-3">$<%= coupon.minOrderAmount %></td>
                <td class="px-4 py-3"><%= coupon.maxUses || 'Unlimited' %></td>
                <td class="px-4 py-3"><%= coupon.usedCount %></td>
                <td class="px-4 py-3"><%= expiryDate.toLocaleDateString() %></td>
                <td class="px-4 py-3">
                  <span class="inline-block px-3 py-1 text-xs font-medium rounded-full <%= effectiveActive ? 'bg-[#1A5D8C] text-white' : 'bg-red-600 text-white' %>">
                    <%= effectiveActive ? 'Active' : 'Inactive' %>
                  </span>
                </td>
                <td class="px-4 py-3">
                  <button class="inline-block px-3 py-1 text-xs font-medium text-white bg-[#1A5D8C] hover:bg-[#154b70] rounded-md transition mr-1"
                          data-edit-coupon
                          data-id="<%= coupon._id %>"
                          data-code="<%= coupon.code %>"
                          data-type="<%= coupon.discountType %>"
                          data-value="<%= coupon.discountValue %>"
                          data-min="<%= coupon.minOrderAmount %>"
                          data-max="<%= coupon.maxUses %>"
                          data-expiry="<%= coupon.expiryDate ? new Date(coupon.expiryDate).toISOString().slice(0, 16) : '' %>"
                          data-active="<%= coupon.isActive %>">
                    Edit
                  </button>
                  <button class="inline-block px-3 py-1 text-xs font-medium text-white bg-red-600 hover:bg-red-700 rounded-md transition"
                          onclick="deleteCoupon('<%= coupon._id %>', '<%= coupon.code %>')">
                    Delete
                  </button>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr><td colspan="10" class="text-center text-gray-500">No coupons found.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>

    <!-- Pagination -->
    <div class="flex justify-center items-center gap-1 py-3">
      <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
        <% if (currentPage > 1) { %>
          <a href="?page=<%= currentPage - 1 %><%= typeof searchQuery !== 'undefined' && searchQuery ? '&search=' + searchQuery : '' %>" class="px-3 py-1.5 border rounded text-sm hover:bg-gray-100">&lt;</a>
        <% } else { %>
          <span class="px-3 py-1.5 text-gray-400">&lt;</span>
        <% } %>

        <% for (let i = 1; i <= totalPages; i++) { %>
          <% if (i === currentPage) { %>
            <span class="px-3 py-1.5 bg-[#1A5D8C] text-white rounded text-sm"><%= i %></span>
          <% } else { %>
            <a href="?page=<%= i %><%= typeof searchQuery !== 'undefined' && searchQuery ? '&search=' + searchQuery : '' %>" class="px-3 py-1.5 border rounded text-sm hover:bg-gray-100"><%= i %></a>
          <% } %>
        <% } %>

        <% if (currentPage < totalPages) { %>
          <a href="?page=<%= currentPage + 1 %><%= typeof searchQuery !== 'undefined' && searchQuery ? '&search=' + searchQuery : '' %>" class="px-3 py-1.5 border rounded text-sm hover:bg-gray-100">&gt;</a>
        <% } else { %>
          <span class="px-3 py-1.5 text-gray-400">&gt;</span>
        <% } %>
      <% } %>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>

<script>
  // Add Coupon Popup (Enhanced UI: Better styling, icons, sections, and responsive layout)
  document.getElementById('showAddCouponPopup').addEventListener('click', () => {
    Swal.fire({
      title: '<i class="fas fa-ticket-alt text-[#1A5D8C]"></i> Create New Coupon',
      html: `
        <div class="text-left space-y-4 p-2">
          <!-- Section: Basic Details -->
          <div class="border-l-4 border-[#1A5D8C] pl-3 bg-blue-50 rounded-md p-3">
            <h4 class="font-semibold text-gray-800 mb-3 flex items-center gap-2"><i class="fas fa-info-circle text-[#1A5D8C]"></i> Basic Details</h4>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Discount Type <span class="text-red-500">*</span></label>
                <select id="swal-type" class="swal2-select w-full border border-gray-300 rounded-md px-3 py-2 focus:ring-2 focus:ring-[#1A5D8C] focus:border-transparent">
                  <option value="">Select Type</option>
                  <option value="percentage">Percentage (% off)</option>
                  <option value="fixed">Fixed Amount ($ off)</option>
                </select>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Discount Value <span class="text-red-500">*</span></label>
                <input id="swal-value" type="number" class="swal2-input border border-gray-300 rounded-md px-3 py-2 focus:ring-2 focus:ring-[#1A5D8C] focus:border-transparent" min="0" step="0.01" placeholder="e.g., 15">
              </div>
            </div>
          </div>

          <!-- Section: Restrictions -->
          <div class="border-l-4 border-yellow-500 pl-3 bg-yellow-50 rounded-md p-3">
            <h4 class="font-semibold text-gray-800 mb-3 flex items-center gap-2"><i class="fas fa-lock text-yellow-500"></i> Restrictions</h4>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Min Order Amount</label>
                <input id="swal-min" type="number" class="swal2-input border border-gray-300 rounded-md px-3 py-2 focus:ring-2 focus:ring-[#1A5D8C] focus:border-transparent" min="0" step="0.01" placeholder="e.g., 50" value="0">
                <p class="text-xs text-gray-500 mt-1">Minimum cart total to apply (optional)</p>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Max Uses (leave empty for unlimited)</label>
                <input id="swal-max" type="number" class="swal2-input border border-gray-300 rounded-md px-3 py-2 focus:ring-2 focus:ring-[#1A5D8C] focus:border-transparent" min="0" placeholder="e.g., 100">
              </div>
            </div>
          </div>

          <!-- Section: Validity -->
          <div class="border-l-4 border-green-500 pl-3 bg-green-50 rounded-md p-3">
            <h4 class="font-semibold text-gray-800 mb-3 flex items-center gap-2"><i class="fas fa-calendar-alt text-green-500"></i> Validity</h4>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Expiry Date <span class="text-red-500">*</span></label>
              <input id="swal-expiry" type="datetime-local" class="swal2-input border border-gray-300 rounded-md px-3 py-2 focus:ring-2 focus:ring-[#1A5D8C] focus:border-transparent w-full">
              <p class="text-xs text-gray-500 mt-1">Coupon expires after this date/time</p>
            </div>
          </div>

          <!-- Help Text -->
          <div class="bg-gray-50 rounded-md p-3 text-xs text-gray-600">
            <i class="fas fa-lightbulb text-yellow-500 mr-1"></i>
            <strong>Tip:</strong> All fields marked with * are required. Coupon code will be auto-generated if not specified.
          </div>
        </div>
      `,
      focusConfirm: false,
      showCancelButton: true,
      confirmButtonText: '<i class="fas fa-save mr-1"></i> Create Coupon',
      cancelButtonText: '<i class="fas fa-times mr-1"></i> Cancel',
      width: '600px',  // Wider for better layout
      customClass: {
        popup: 'rounded-xl shadow-2xl',
        title: 'text-[#154b70] font-bold text-lg',
        confirmButton: 'bg-[#1A5D8C] hover:bg-[#154b70] text-white px-6 py-2 rounded-md font-medium shadow-md',
        cancelButton: 'bg-gray-200 hover:bg-gray-300 text-gray-700 px-6 py-2 rounded-md font-medium shadow-md',
        htmlContainer: 'text-sm'
      },
      preConfirm: () => {
        const type = document.getElementById('swal-type').value;
        const value = parseFloat(document.getElementById('swal-value').value);
        const minOrder = parseFloat(document.getElementById('swal-min').value) || 0;
        const maxUses = document.getElementById('swal-max').value ? parseInt(document.getElementById('swal-max').value) : null;
        const expiry = document.getElementById('swal-expiry').value;

        if (!type || isNaN(value) || value <= 0 || !expiry) {
          Swal.showValidationMessage('<i class="fas fa-exclamation-triangle text-red-500 mr-1"></i>Please fill all required fields correctly');
          return false;
        }
        if (new Date(expiry) <= new Date()) {
          Swal.showValidationMessage('<i class="fas fa-clock text-red-500 mr-1"></i>Expiry must be in the future');
          return false;
        }
        return { discountType: type, discountValue: value, minOrderAmount: minOrder, maxUses, expiryDate: expiry };
      }
    }).then((result) => {
      if (result.isConfirmed) {
        const data = result.value;
        Swal.fire({ title: 'Adding...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
        fetch('/admin/coupon', {  // Fixed: No 's' to match route
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + localStorage.getItem('token') },
          body: JSON.stringify(data)
        }).then(async res => {
          if (!res.ok) {
            const errText = await res.text();  // Log HTML for debug
            console.error('Fetch error response (HTML?):', errText);
            throw new Error(`Server error ${res.status}: ${res.statusText}`);
          }
          const response = await res.json();  // Safe now
          // Add row dynamically (unchanged)
          const tbody = document.getElementById('couponTableBody');
          const newRow = document.createElement('tr');
          newRow.className = 'hover:bg-gray-50 transition animate-fadeIn';
          newRow.dataset.id = response.data._id;
          newRow.innerHTML = `
            <td class="px-4 py-3">1</td>
            <td class="px-4 py-3 font-medium">${response.data.code}</td>
            <td class="px-4 py-3"><span class="inline-block px-2 py-1 text-xs font-medium rounded-full bg-blue-100 text-blue-800">${response.data.discountType}</span></td>
            <td class="px-4 py-3">${response.data.discountValue} ${response.data.discountType === 'percentage' ? '%' : '$'}</td>
            <td class="px-4 py-3">$${response.data.minOrderAmount}</td>
            <td class="px-4 py-3">${response.data.maxUses || 'Unlimited'}</td>
            <td class="px-4 py-3">0</td>
            <td class="px-4 py-3">${new Date(response.data.expiryDate).toLocaleDateString()}</td>
            <td class="px-4 py-3"><span class="inline-block px-3 py-1 text-xs font-medium rounded-full bg-[#1A5D8C] text-white">Active</span></td>
            <td class="px-4 py-3">
              <button class="inline-block px-3 py-1 text-xs font-medium text-white bg-[#1A5D8C] hover:bg-[#154b70] rounded-md transition mr-1" data-edit-coupon data-id="${response.data._id}" data-code="${response.data.code}" data-type="${response.data.discountType}" data-value="${response.data.discountValue}" data-min="${response.data.minOrderAmount}" data-max="${response.data.maxUses}" data-expiry="${new Date(response.data.expiryDate).toISOString().slice(0, 16)}" data-active="${response.data.isActive}">Edit</button>
              <button class="inline-block px-3 py-1 text-xs font-medium text-white bg-red-600 hover:bg-red-700 rounded-md transition" onclick="deleteCoupon('${response.data._id}', '${response.data.code}')">Delete</button>
            </td>
          `;
          tbody.insertBefore(newRow, tbody.firstChild);
          const rows = tbody.querySelectorAll('tr');
          rows.forEach((row, idx) => row.querySelector('td:first-child').textContent = idx + 1);
          const itemsPerPage = <%= itemsPerPage || 10 %>;
          if (rows.length > itemsPerPage) tbody.removeChild(rows[rows.length - 1]);
          Swal.fire({
            icon: 'success',
            title: '<i class="fas fa-check-circle text-green-500 mr-2"></i> Success!',
            text: 'Coupon created and added to the list!',
            timer: 2000,
            showConfirmButton: false
          });
        }).catch(err => {
          console.error('Full error:', err);  // Log for debug
          Swal.fire({
            icon: 'error',
            title: '<i class="fas fa-exclamation-triangle text-red-500 mr-2"></i> Error',
            text: err.message
          });
        });
      }
    });
  });

  // Edit Coupon Popup (Full implementation with prefill and code input)
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('[data-edit-coupon]').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = btn.dataset.id;
        const code = btn.dataset.code;
        const type = btn.dataset.type;
        const value = btn.dataset.value;
        const min = btn.dataset.min;
        const max = btn.dataset.max;
        const expiry = btn.dataset.expiry;
        const active = btn.dataset.active === 'true';

        Swal.fire({
          title: '<i class="fas fa-edit text-[#1A5D8C]"></i> Edit Coupon',
          html: `
            <div class="text-left space-y-4 p-2">
              <!-- Section: Basic Details -->
              <div class="border-l-4 border-[#1A5D8C] pl-3 bg-blue-50 rounded-md p-3">
                <h4 class="font-semibold text-gray-800 mb-3 flex items-center gap-2"><i class="fas fa-info-circle text-[#1A5D8C]"></i> Basic Details</h4>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                  <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Code</label>
                    <input id="swal-edit-code" type="text" class="swal2-input border border-gray-300 rounded-md px-3 py-2 focus:ring-2 focus:ring-[#1A5D8C] focus:border-transparent" placeholder="e.g., SAVE10" value="${code}">
                    <p class="text-xs text-gray-500 mt-1">Leave empty to auto-generate (optional)</p>
                  </div>
                  <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Discount Type <span class="text-red-500">*</span></label>
                    <select id="swal-edit-type" class="swal2-select w-full border border-gray-300 rounded-md px-3 py-2 focus:ring-2 focus:ring-[#1A5D8C] focus:border-transparent">
                      <option value="">Select Type</option>
                      <option value="percentage" ${type === 'percentage' ? 'selected' : ''}>Percentage (% off)</option>
                      <option value="fixed" ${type === 'fixed' ? 'selected' : ''}>Fixed Amount ($ off)</option>
                    </select>
                  </div>
                  <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Discount Value <span class="text-red-500">*</span></label>
                    <input id="swal-edit-value" type="number" class="swal2-input border border-gray-300 rounded-md px-3 py-2 focus:ring-2 focus:ring-[#1A5D8C] focus:border-transparent" min="0" step="0.01" value="${value}" placeholder="e.g., 15">
                  </div>
                </div>
              </div>

              <!-- Section: Restrictions -->
              <div class="border-l-4 border-yellow-500 pl-3 bg-yellow-50 rounded-md p-3">
                <h4 class="font-semibold text-gray-800 mb-3 flex items-center gap-2"><i class="fas fa-lock text-yellow-500"></i> Restrictions</h4>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                  <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Min Order Amount</label>
                    <input id="swal-edit-min" type="number" class="swal2-input border border-gray-300 rounded-md px-3 py-2 focus:ring-2 focus:ring-[#1A5D8C] focus:border-transparent" min="0" step="0.01" value="${min}" placeholder="e.g., 50">
                    <p class="text-xs text-gray-500 mt-1">Minimum cart total to apply (optional)</p>
                  </div>
                  <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Max Uses (leave empty for unlimited)</label>
                    <input id="swal-edit-max" type="number" class="swal2-input border border-gray-300 rounded-md px-3 py-2 focus:ring-2 focus:ring-[#1A5D8C] focus:border-transparent" min="0" value="${max || ''}" placeholder="e.g., 100">
                  </div>
                </div>
              </div>

              <!-- Section: Validity -->
              <div class="border-l-4 border-green-500 pl-3 bg-green-50 rounded-md p-3">
                <h4 class="font-semibold text-gray-800 mb-3 flex items-center gap-2"><i class="fas fa-calendar-alt text-green-500"></i> Validity & Status</h4>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                  <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Expiry Date <span class="text-red-500">*</span></label>
                    <input id="swal-edit-expiry" type="datetime-local" class="swal2-input border border-gray-300 rounded-md px-3 py-2 focus:ring-2 focus:ring-[#1A5D8C] focus:border-transparent w-full" value="${expiry}">
                    <p class="text-xs text-gray-500 mt-1">Set to past to expire immediately</p>
                  </div>
                  <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Manual Status</label>
                    <select id="swal-edit-active" class="swal2-select w-full border border-gray-300 rounded-md px-3 py-2 focus:ring-2 focus:ring-[#1A5D8C] focus:border-transparent">
                      <option value="true" ${active ? 'selected' : ''}>Active (unless expired)</option>
                      <option value="false" ${!active ? 'selected' : ''}>Inactive</option>
                    </select>
                    <p class="text-xs text-gray-500 mt-1">Final status also considers expiry date</p>
                  </div>
                </div>
              </div>

              <!-- Help Text -->
              <div class="bg-gray-50 rounded-md p-3 text-xs text-gray-600">
                <i class="fas fa-lightbulb text-yellow-500 mr-1"></i>
                <strong>Tip:</strong> All fields marked with * are required. Changes apply immediately.
              </div>
            </div>
          `,
          focusConfirm: false,
          showCancelButton: true,
          confirmButtonText: '<i class="fas fa-save mr-1"></i> Update Coupon',
          cancelButtonText: '<i class="fas fa-times mr-1"></i> Cancel',
          width: '600px',
          customClass: {
            popup: 'rounded-xl shadow-2xl',
            title: 'text-[#154b70] font-bold text-lg',
            confirmButton: 'bg-[#1A5D8C] hover:bg-[#154b70] text-white px-6 py-2 rounded-md font-medium shadow-md',
            cancelButton: 'bg-gray-200 hover:bg-gray-300 text-gray-700 px-6 py-2 rounded-md font-medium shadow-md',
            htmlContainer: 'text-sm'
          },
          preConfirm: () => {
            const code = document.getElementById('swal-edit-code').value.trim() || undefined;
            const type = document.getElementById('swal-edit-type').value;
            const value = parseFloat(document.getElementById('swal-edit-value').value);
            const minOrder = parseFloat(document.getElementById('swal-edit-min').value) || 0;
            const maxUses = document.getElementById('swal-edit-max').value ? parseInt(document.getElementById('swal-edit-max').value) : null;
            const expiry = document.getElementById('swal-edit-expiry').value;
            const isActive = document.getElementById('swal-edit-active').value === 'true';

            if (!type || isNaN(value) || value <= 0 || !expiry) {
              Swal.showValidationMessage('<i class="fas fa-exclamation-triangle text-red-500 mr-1"></i>Please fill all required fields correctly');
              return false;
            }
            return { code, discountType: type, discountValue: value, minOrderAmount: minOrder, maxUses, expiryDate: expiry, isActive };
          }
        }).then((result) => {
          if (result.isConfirmed) {
            const formValues = result.value;
            Swal.fire({ title: 'Updating...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });
            fetch(`/admin/coupon/${id}`, {
              method: 'PUT',
              headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + localStorage.getItem('token') },
              body: JSON.stringify(formValues)
            }).then(async res => {
              if (!res.ok) {
                const errText = await res.text();
                console.error('PUT error response:', errText);
                throw new Error(`Server error ${res.status}: ${res.statusText}`);
              }
              const data = await res.json();
              // Update row dynamically
              const row = document.querySelector(`tr[data-id="${id}"]`);
              const effectiveActive = data.data.isActive && new Date(data.data.expiryDate) >= new Date();
              row.innerHTML = `
                <td class="px-4 py-3">${row.cells[0].textContent}</td>
                <td class="px-4 py-3 font-medium">${data.data.code || code}</td>
                <td class="px-4 py-3"><span class="inline-block px-2 py-1 text-xs font-medium rounded-full bg-blue-100 text-blue-800">${data.data.discountType}</span></td>
                <td class="px-4 py-3">${data.data.discountValue} ${data.data.discountType === 'percentage' ? '%' : '$'}</td>
                <td class="px-4 py-3">$${data.data.minOrderAmount}</td>
                <td class="px-4 py-3">${data.data.maxUses || 'Unlimited'}</td>
                <td class="px-4 py-3">${data.data.usedCount}</td>
                <td class="px-4 py-3">${new Date(data.data.expiryDate).toLocaleDateString()}</td>
                <td class="px-4 py-3"><span class="inline-block px-3 py-1 text-xs font-medium rounded-full ${effectiveActive ? 'bg-[#1A5D8C] text-white' : 'bg-red-600 text-white'}">${effectiveActive ? 'Active' : 'Inactive'}</span></td>
                <td class="px-4 py-3">
                  <button class="inline-block px-3 py-1 text-xs font-medium text-white bg-[#1A5D8C] hover:bg-[#154b70] rounded-md transition mr-1" data-edit-coupon data-id="${data.data._id}" data-code="${data.data.code}" data-type="${data.data.discountType}" data-value="${data.data.discountValue}" data-min="${data.data.minOrderAmount}" data-max="${data.data.maxUses}" data-expiry="${new Date(data.data.expiryDate).toISOString().slice(0, 16)}" data-active="${data.data.isActive}">Edit</button>
                  <button class="inline-block px-3 py-1 text-xs font-medium text-white bg-red-600 hover:bg-red-700 rounded-md transition" onclick="deleteCoupon('${data.data._id}', '${data.data.code}')">Delete</button>
                </td>
              `;
              // Re-attach event listener
              const newEditBtn = row.querySelector('[data-edit-coupon]');
              newEditBtn.addEventListener('click', () => {
                // Recursive call or re-run the handler logic
                // For simplicity, since DOMContentLoaded already ran, we can trigger a custom event or just let the existing listener catch it (but since replaced, need to re-bind)
                // Better: move the binding outside and use event delegation
              });
              // Note: To handle dynamic rows properly, consider event delegation on document for [data-edit-coupon]
              Swal.fire({
                icon: 'success',
                title: '<i class="fas fa-check-circle text-green-500 mr-2"></i> Success!',
                text: 'Coupon updated!',
                timer: 2000,
                showConfirmButton: false
              });
            }).catch(err => {
              console.error('Edit error:', err);
              Swal.fire({
                icon: 'error',
                title: '<i class="fas fa-exclamation-triangle text-red-500 mr-2"></i> Error',
                text: err.message
              });
            });
          }
        });
      });
    });
  });

  // Event delegation for edit buttons (to handle dynamic rows)
  document.addEventListener('click', (e) => {
    if (e.target.matches('[data-edit-coupon]')) {
      // Trigger the edit logic here (extract to function if needed)
      e.target.click(); // Or implement the handler inline
    }
  });

  // Delete Coupon (Fixed path: /admin/coupon/:id)
  function deleteCoupon(id, code) {
    const usedCount = $(`tr[data-id="${id}"] td:nth-child(7)`).text();
    const confirmText = usedCount > 0 ? `This coupon has been used ${usedCount} times. Deactivating will prevent future use.` : `Deactivate "${code}"?`;
    Swal.fire({
      title: 'Deactivate Coupon?',
      text: confirmText,
      icon: 'warning',
      showCancelButton: true,
      confirmButtonText: 'Yes, Deactivate',
      confirmButtonColor: '#1A5D8C'
    }).then(result => {
      if (result.isConfirmed) {
        fetch(`/admin/coupon/${id}`, {
          method: 'DELETE',
          headers: { 'Authorization': 'Bearer ' + localStorage.getItem('token') }
        })
        .then(async res => {
          if (!res.ok) {
            const errText = await res.text();
            console.error('DELETE error response:', errText);
            throw new Error(`Server error ${res.status}: ${res.statusText}`);
          }
          const data = await res.json();
          if (data.message) {
            $(`tr[data-id="${id}"]`).remove();
            // Update S.No. for remaining rows
            const rows = $('#couponTableBody tr');
            rows.each((idx, row) => {
              $(row).find('td:first-child').text(idx + 1);
            });
            Swal.fire('Success!', 'Coupon deactivated!', 'success');
          } else {
            Swal.fire('Error', data.error, 'error');
          }
        }).catch(err => {
          console.error('Delete error:', err);
          Swal.fire('Error', err.message, 'error');
        });
      }
    });
  }
</script>

