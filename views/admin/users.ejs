<%- include("../../views/partials/admin/header") %>

<div class="min-h-screen flex items-center justify-center p-4">
  <div class="max-w-5xl w-full bg-white rounded-xl shadow-lg p-6 space-y-6 ml-8 md:ml-16 lg:ml-24">

    <!-- Header -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 pb-4 border-b-2 border-[#1A5D8C]">
      <h1 class="text-[#154b70] text-2xl font-bold">Users</h1>

      <div class="flex items-center gap-3 w-full sm:w-auto">
        <form id="searchForm" class="flex items-center bg-[#1A5D8C] rounded-md overflow-hidden flex-1 sm:flex-initial">
          <input
            type="text"
            id="searchInput"
            placeholder="Search users..."
            value="<%= typeof search !== 'undefined' ? search : '' %>"
            class="w-full sm:w-64 px-3 py-2 bg-transparent text-white placeholder-white/70 outline-none text-sm"
          />
          <button type="submit" class="px-3 text-white text-sm">Search</button>
        </form>

        <button
          id="cancelButton"
          type="button"
          class="text-[#1A5D8C] underline text-sm whitespace-nowrap <%= (typeof search !== 'undefined' && search) ? '' : 'hidden' %>">
          Clear
        </button>
      </div>
    </div>

    <!-- Table -->
    <div class="flex justify-center">
      <table id="userTable" class="w-full text-sm max-w-4xl">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-4 py-3 text-left font-medium text-[#1A5D8C]">S.No.</th>
            <th class="px-4 py-3 text-left font-medium text-[#1A5D8C]">Name</th>
            <th class="px-4 py-3 text-left font-medium text-[#1A5D8C]">Email</th>
            <th class="px-4 py-3 text-left font-medium text-[#1A5D8C]">Phone</th>
            <th class="px-4 py-3 text-left font-medium text-[#1A5D8C]">Status</th>
            <th class="px-4 py-3 text-left font-medium text-[#1A5D8C]">Action</th>
          </tr>
        </thead>
        <tbody id="userTableBody" class="divide-y divide-gray-200">
          <% data.forEach((user, index) => { %>
            <tr class="hover:bg-gray-50 transition">
              <td class="px-4 py-3"><%= (currentPage - 1) * 5 + index + 1 %></td>
              <td class="px-4 py-3 font-medium"><%= user.name %></td>
              <td class="px-4 py-3 text-gray-600"><%= user.email %></td>
              <td class="px-4 py-3 text-gray-600"><%= user.phone || '—' %></td>
              <td class="px-4 py-3">
                <span class="inline-block px-3 py-1 text-xs font-medium rounded-full <%= user.isBlocked ? 'bg-red-600 text-white' : 'bg-[#1A5D8C] text-white' %>">
                  <%= user.isBlocked ? 'Blocked' : 'Active' %>
                </span>
              </td>
              <td class="px-4 py-3">
                <% if (user.isBlocked) { %>
                  <button class="btn-unblock inline-block px-3 py-1 text-xs font-medium text-white bg-green-600 hover:bg-green-700 rounded-md transition" data-id="<%= user._id %>">
                    Unblock
                  </button>
                <% } else { %>
                  <button class="btn-block inline-block px-3 py-1 text-xs font-medium text-white bg-red-600 hover:bg-red-700 rounded-md transition" data-id="<%= user._id %>">
                    Block
                  </button>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <!-- Pagination -->
    <div id="pagination" class="flex justify-center items-center gap-1 py-3">
      <% if (totalPages > 1) { %>
        <% if (currentPage > 1) { %>
          <button class="pagination-btn px-3 py-1.5 border rounded text-sm hover:bg-gray-100" data-page="<%= currentPage - 1 %>">&lt;</button>
        <% } else { %>
          <span class="px-3 py-1.5 text-gray-400">&lt;</span>
        <% } %>

        <% for (let i = 1; i <= totalPages; i++) { %>
          <% if (i === currentPage) { %>
            <span class="px-3 py-1.5 bg-[#1A5D8C] text-white rounded text-sm"><%= i %></span>
          <% } else { %>
            <button class="pagination-btn px-3 py-1.5 border rounded text-sm hover:bg-gray-100" data-page="<%= i %>"><%= i %></button>
          <% } %>
        <% } %>

        <% if (currentPage < totalPages) { %>
          <button class="pagination-btn px-3 py-1.5 border rounded text-sm hover:bg-gray-100" data-page="<%= currentPage + 1 %>">&gt;</button>
        <% } else { %>
          <span class="px-3 py-1.5 text-gray-400">&gt;</span>
        <% } %>
      <% } %>
    </div>

  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
  let currentSearch = '<%= (typeof search !== "undefined" ? search : "").replace(/'/g, "\\'") %>';
  let currentPage   = <%= currentPage %>;
  const tbody       = document.getElementById('userTableBody');
  const paginationDiv = document.getElementById('pagination');
  const limit = 5;

  // ── Fetch & render ────────────────────────────────────────────
  async function fetchUsers(search = '', page = 1) {
    try {
      const res  = await fetch(`/admin/users?search=${encodeURIComponent(search)}&page=${page}`, {
        headers: { Accept: 'application/json' }
      });
      const data = await res.json();
      renderUsers(data.users, page);
      renderPagination(data.totalPages, data.currentPage);
    } catch (err) {
      console.error('Fetch error:', err);
    }
  }

  function renderUsers(users, page) {
    if (!users || users.length === 0) {
      tbody.innerHTML = '<tr><td colspan="6" class="px-4 py-8 text-center text-gray-400">No users found</td></tr>';
      return;
    }
    tbody.innerHTML = users.map((user, index) => `
      <tr class="hover:bg-gray-50 transition">
        <td class="px-4 py-3">${(page - 1) * limit + index + 1}</td>
        <td class="px-4 py-3 font-medium">${user.name}</td>
        <td class="px-4 py-3 text-gray-600">${user.email}</td>
        <td class="px-4 py-3 text-gray-600">${user.phone || '—'}</td>
        <td class="px-4 py-3">
          <span class="inline-block px-3 py-1 text-xs font-medium rounded-full ${user.isBlocked ? 'bg-red-600 text-white' : 'bg-[#1A5D8C] text-white'}">
            ${user.isBlocked ? 'Blocked' : 'Active'}
          </span>
        </td>
        <td class="px-4 py-3">
          ${user.isBlocked
            ? `<button class="btn-unblock inline-block px-3 py-1 text-xs font-medium text-white bg-green-600 hover:bg-green-700 rounded-md transition" data-id="${user._id}">Unblock</button>`
            : `<button class="btn-block inline-block px-3 py-1 text-xs font-medium text-white bg-red-600 hover:bg-red-700 rounded-md transition" data-id="${user._id}">Block</button>`
          }
        </td>
      </tr>
    `).join('');
    attachListeners();
  }

  function renderPagination(totalPages, current) {
    if (totalPages <= 1) { paginationDiv.innerHTML = ''; return; }
    let html = '';
    if (current > 1) html += `<button class="pagination-btn px-3 py-1.5 border rounded text-sm hover:bg-gray-100" data-page="${current - 1}">&lt;</button>`;
    else html += `<span class="px-3 py-1.5 text-gray-400">&lt;</span>`;

    for (let i = 1; i <= totalPages; i++) {
      if (i === current) html += `<span class="px-3 py-1.5 bg-[#1A5D8C] text-white rounded text-sm">${i}</span>`;
      else html += `<button class="pagination-btn px-3 py-1.5 border rounded text-sm hover:bg-gray-100" data-page="${i}">${i}</button>`;
    }

    if (current < totalPages) html += `<button class="pagination-btn px-3 py-1.5 border rounded text-sm hover:bg-gray-100" data-page="${current + 1}">&gt;</button>`;
    else html += `<span class="px-3 py-1.5 text-gray-400">&gt;</span>`;

    paginationDiv.innerHTML = html;
    paginationDiv.querySelectorAll('.pagination-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        currentPage = parseInt(btn.dataset.page);
        fetchUsers(currentSearch, currentPage);
      });
    });
  }

  // ── Search ────────────────────────────────────────────────────
  document.getElementById('searchForm').addEventListener('submit', e => {
    e.preventDefault();
    currentSearch = document.getElementById('searchInput').value.trim();
    currentPage = 1;
    toggleClear();
    fetchUsers(currentSearch, currentPage);
  });

  document.getElementById('cancelButton').addEventListener('click', () => {
    document.getElementById('searchInput').value = '';
    currentSearch = '';
    currentPage = 1;
    toggleClear();
    fetchUsers('', 1);
  });

  function toggleClear() {
    const val = document.getElementById('searchInput').value.trim();
    document.getElementById('cancelButton').classList.toggle('hidden', !val);
  }

  document.getElementById('searchInput').addEventListener('input', toggleClear);

  // ── Block / Unblock ───────────────────────────────────────────
  function attachListeners() {
    document.querySelectorAll('.btn-block, .btn-unblock').forEach(btn => {
      btn.addEventListener('click', async () => {
        const userId    = btn.dataset.id;
        const isBlocking = btn.classList.contains('btn-block');
        const action    = isBlocking ? 'block' : 'unblock';

        const result = await Swal.fire({
          title: `${isBlocking ? 'Block' : 'Unblock'} user?`,
          text: isBlocking
            ? 'This user will be blocked and cannot log in.'
            : 'This user will be unblocked and can log in again.',
          icon: 'warning',
          showCancelButton: true,
          confirmButtonColor: isBlocking ? '#dc2626' : '#16a34a',
          cancelButtonColor: '#6c757d',
          confirmButtonText: isBlocking ? 'Yes, Block' : 'Yes, Unblock',
          cancelButtonText: 'Cancel'
        });

        if (!result.isConfirmed) return;

        const url = isBlocking ? `/admin/blockUser?id=${userId}` : `/admin/unblockUser?id=${userId}`;
        try {
          const res = await fetch(url, { method: 'GET' });
          if (res.ok) {
            fetchUsers(currentSearch, currentPage);
            Swal.fire({
              icon: 'success',
              title: isBlocking ? 'User Blocked' : 'User Unblocked',
              timer: 1500,
              showConfirmButton: false
            });
          } else {
            Swal.fire('Error', 'Action failed. Please try again.', 'error');
          }
        } catch (err) {
          Swal.fire('Error', 'Something went wrong.', 'error');
        }
      });
    });
  }

  // ── Static pagination buttons (server-rendered) ───────────────
  document.querySelectorAll('.pagination-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      currentPage = parseInt(btn.dataset.page);
      fetchUsers(currentSearch, currentPage);
    });
  });

  // ── Attach listeners to server-rendered rows on first load ────
  attachListeners();
</script>

<%- include("../../views/partials/admin/footer") %>
