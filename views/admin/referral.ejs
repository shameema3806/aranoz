<%- include("../../views/partials/admin/header") %>

  <!-- ====================== MAIN CONTENT ====================== -->
  <div class="ml-64 pt-12 bg-gray-100 min-h-screen p-6">
    <div class="max-w-full w-full bg-white rounded-xl shadow-lg p-6 space-y-6">

      <div
        class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 pb-4 border-b-2 border-[#1A5D8C]">
        <h1 class="text-[#154b70] text-2xl font-bold">Referral Program</h1>

        <div class="flex items-center gap-3 w-full sm:w-auto">
          <form action="/admin/referral" method="get"
            class="flex items-center bg-[#1A5D8C] rounded-md overflow-hidden flex-1 sm:flex-initial">
            <input type="text" name="search" placeholder="Search referrals..."
              value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>"
              class="w-full sm:w-64 px-3 py-2 bg-transparent text-white placeholder-white/70 outline-none text-sm" />
            <button type="submit" class="px-3 text-white">
              Search
            </button>
          </form>

          <% if (typeof searchQuery !=='undefined' && searchQuery) { %>
            <a href="/admin/referral" class="text-[#1A5D8C] underline text-sm whitespace-nowrap">Clear</a>
            <% } %>

              <button id="showConfigPopup"
                class="bg-[#1A5D8C] hover:bg-[#154b70] text-white font-medium px-4 py-2 rounded-md transition flex items-center gap-2 text-sm whitespace-nowrap">
                <i class="fas fa-cog"></i> Configure Rewards
              </button>
        </div>
      </div>

      <!-- Stats Cards -->
      <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
        <div class="bg-gradient-to-br from-blue-500 to-blue-600 rounded-lg p-4 text-white shadow-md">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm opacity-90">Total Referrals</p>
              <h3 class="text-2xl font-bold mt-1">
                <%= typeof stats !=='undefined' ? stats.totalReferrals : 0 %>
              </h3>
            </div>
            <i class="fas fa-users text-3xl opacity-80"></i>
          </div>
        </div>

        <div class="bg-gradient-to-br from-green-500 to-green-600 rounded-lg p-4 text-white shadow-md">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm opacity-90">Successful Conversions</p>
              <h3 class="text-2xl font-bold mt-1">
                <%= typeof stats !=='undefined' ? stats.successfulReferrals : 0 %>
              </h3>
            </div>
            <i class="fas fa-check-circle text-3xl opacity-80"></i>
          </div>
        </div>

        <div class="bg-gradient-to-br from-purple-500 to-purple-600 rounded-lg p-4 text-white shadow-md">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm opacity-90">Rewards Issued</p>
              <h3 class="text-2xl font-bold mt-1">
                <%= typeof stats !=='undefined' ? stats.rewardsIssued : 0 %>
              </h3>
            </div>
            <i class="fas fa-gift text-3xl opacity-80"></i>
          </div>
        </div>

        <div class="bg-gradient-to-br from-orange-500 to-orange-600 rounded-lg p-4 text-white shadow-md">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm opacity-90">Pending Rewards</p>
              <h3 class="text-2xl font-bold mt-1">
                <%= typeof stats !=='undefined' ? stats.pendingRewards : 0 %>
              </h3>
            </div>
            <i class="fas fa-clock text-3xl opacity-80"></i>
          </div>
        </div>
      </div>

      <!-- Tabs -->
      <div class="border-b border-gray-200">
        <nav class="flex gap-4">
          <button class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-[#1A5D8C] text-[#1A5D8C]"
            data-tab="referrals">
            <i class="fas fa-list mr-2"></i>All Referrals
          </button>
          <button
            class="tab-btn px-4 py-2 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-[#1A5D8C]"
            data-tab="config">
            <i class="fas fa-sliders-h mr-2"></i>Program Configuration
          </button>
        </nav>
      </div>

      <!-- Tab Content: Referrals Table -->
      <div id="tab-referrals" class="tab-content">
        <div class="overflow-x-auto">
          <table id="referralTable" class="w-full text-sm min-w-max">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-4 py-3 text-left font-medium text-[#1A5D8C]">S.No.</th>
                <th class="px-4 py-3 text-left font-medium text-[#1A5D8C]">Referrer</th>
                <th class="px-4 py-3 text-left font-medium text-[#1A5D8C]">Referral Code</th>
                <th class="px-4 py-3 text-left font-medium text-[#1A5D8C]">Referred User</th>
                <th class="px-4 py-3 text-left font-medium text-[#1A5D8C]">Method</th>
                <th class="px-4 py-3 text-left font-medium text-[#1A5D8C]">Date</th>
                <th class="px-4 py-3 text-left font-medium text-[#1A5D8C]">Reward Status</th>
                <th class="px-4 py-3 text-left font-medium text-[#1A5D8C]">Actions</th>
              </tr>
            </thead>
            <tbody id="referralTableBody" class="divide-y divide-gray-200">
              <% if (typeof referrals !=='undefined' && referrals.length> 0) { %>
                <% referrals.forEach((referral, index)=> { %>
                  <tr class="hover:bg-gray-50 transition" data-id="<%= referral.referralId %>">
                    <td class="px-4 py-3">
                      <%= (currentPage - 1) * itemsPerPage + index + 1 %>
                    </td>
                    <td class="px-4 py-3">
                      <div class="flex items-center gap-2">
                        <div
                          class="w-8 h-8 bg-[#1A5D8C] text-white rounded-full flex items-center justify-center text-xs font-bold">
                          <%= referral.referrer?.name?.charAt(0).toUpperCase() || 'U' %>
                        </div>
                        <div>
                          <p class="font-medium">
                            <%= referral.referrer?.name || 'Unknown' %>
                          </p>
                          <p class="text-xs text-gray-500">
                            <%= referral.referrer?.email || 'N/A' %>
                          </p>
                        </div>
                      </div>
                    </td>
                    <td class="px-4 py-3">
                      <code
                        class="bg-gray-100 px-2 py-1 rounded text-xs font-mono"><%= referral.referralCode || 'N/A' %></code>
                    </td>
                    <td class="px-4 py-3">
                      <% if (referral.referredUser) { %>
                        <div>
                          <p class="font-medium">
                            <%= referral.referredUser.name %>
                          </p>
                          <p class="text-xs text-gray-500">
                            <%= referral.referredUser.email %>
                          </p>
                        </div>
                        <% } else { %>
                          <span class="text-gray-400 italic">Pending</span>
                          <% } %>
                    </td>
                    <td class="px-4 py-3">
                      <span
                        class="inline-block px-2 py-1 text-xs font-medium rounded-full <%= referral.method === 'token' ? 'bg-purple-100 text-purple-800' : 'bg-blue-100 text-blue-800' %>">
                        <i class="fas <%= referral.method === 'token' ? 'fa-link' : 'fa-code' %> mr-1"></i>
                        <%= referral.method==='token' ? 'Token URL' : 'Referral Code' %>
                      </span>
                    </td>
                    <td class="px-4 py-3">
                      <%= new Date(referral.createdAt).toLocaleDateString() %>
                    </td>
                    <td class="px-4 py-3">
                      <span
                        class="inline-block px-3 py-1 text-xs font-medium rounded-full <%= referral.rewardIssued ? 'bg-green-600 text-white' : 'bg-yellow-500 text-white' %>">
                        <%= referral.rewardIssued ? 'Issued' : 'Pending' %>
                      </span>
                    </td>
                    <td class="px-4 py-3">
                      <button
                        class="inline-block px-3 py-1 text-xs font-medium text-white bg-[#1A5D8C] hover:bg-[#154b70] rounded-md transition mr-1"
                        onclick="viewReferralDetails('<%= referral.referralId %>')">
                        <i class="fas fa-eye mr-1"></i>View
                      </button>
                      <% if (!referral.rewardIssued && referral.referredUser) { %>
                        <button
                          class="inline-block px-3 py-1 text-xs font-medium text-white bg-green-600 hover:bg-green-700 rounded-md transition"
                          onclick="issueReward('<%= referral.referralId %>')">
                          <i class="fas fa-gift mr-1"></i>Issue
                        </button>
                        <% } %>
                    </td>
                  </tr>
                  <% }) %>
                    <% } else { %>
                      <tr>
                        <td colspan="8" class="text-center text-gray-500 py-6">No referrals found.</td>
                      </tr>
                      <% } %>
            </tbody>
          </table>
        </div>

        <!-- Pagination -->
        <div class="flex justify-center items-center gap-1 py-3">
          <% if (typeof totalPages !=='undefined' && totalPages> 1) { %>
            <% if (currentPage> 1) { %>
              <a href="?page=<%= currentPage - 1 %><%= typeof searchQuery !== 'undefined' && searchQuery ? '&search=' + searchQuery : '' %>"
                class="px-3 py-1.5 border rounded text-sm hover:bg-gray-100">&lt;</a>
              <% } else { %>
                <span class="px-3 py-1.5 text-gray-400">&lt;</span>
                <% } %>

                  <% for (let i=1; i <=totalPages; i++) { %>
                    <% if (i===currentPage) { %>
                      <span class="px-3 py-1.5 bg-[#1A5D8C] text-white rounded text-sm">
                        <%= i %>
                      </span>
                      <% } else { %>
                        <a href="?page=<%= i %><%= typeof searchQuery !== 'undefined' && searchQuery ? '&search=' + searchQuery : '' %>"
                          class="px-3 py-1.5 border rounded text-sm hover:bg-gray-100">
                          <%= i %>
                        </a>
                        <% } %>
                          <% } %>

                            <% if (currentPage < totalPages) { %>
                              <a href="?page=<%= currentPage + 1 %><%= typeof searchQuery !== 'undefined' && searchQuery ? '&search=' + searchQuery : '' %>"
                                class="px-3 py-1.5 border rounded text-sm hover:bg-gray-100">&gt;</a>
                              <% } else { %>
                                <span class="px-3 py-1.5 text-gray-400">&gt;</span>
                                <% } %>
                                  <% } %>
        </div>
      </div>

      <!-- Tab Content: Configuration -->
      <div id="tab-config" class="tab-content hidden">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <!-- Reward Configuration Card -->
          <div class="border border-gray-200 rounded-lg p-6 space-y-4">
            <h3 class="text-lg font-semibold text-[#154b70] flex items-center gap-2">
              <i class="fas fa-gift text-[#1A5D8C]"></i>
              Reward Settings
            </h3>
            <div class="space-y-3">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Reward Type</label>
                <select id="config-reward-type" class="w-full border border-gray-300 rounded-md px-3 py-2">
                  <option value="percentage">Percentage Discount</option>
                  <option value="fixed">Fixed Amount</option>
                </select>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Reward Value</label>
                <input id="config-reward-value" type="number" min="0" step="0.01"
                  class="w-full border border-gray-300 rounded-md px-3 py-2" placeholder="e.g., 10">
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Min Order for Reward</label>
                <input id="config-min-order" type="number" min="0" step="0.01"
                  class="w-full border border-gray-300 rounded-md px-3 py-2" placeholder="e.g., 50" value="0">
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Reward Expiry (days)</label>
                <input id="config-expiry-days" type="number" min="1"
                  class="w-full border border-gray-300 rounded-md px-3 py-2" placeholder="e.g., 30" value="30">
              </div>
            </div>
          </div>

          <!-- Program Settings Card -->
          <div class="border border-gray-200 rounded-lg p-6 space-y-4">
            <h3 class="text-lg font-semibold text-[#154b70] flex items-center gap-2">
              <i class="fas fa-cogs text-[#1A5D8C]"></i>
              Program Settings
            </h3>
            <div class="space-y-3">
              <div class="flex items-center justify-between">
                <label class="text-sm font-medium text-gray-700">Enable Token URL Method</label>
                <label class="relative inline-flex items-center cursor-pointer">
                  <input type="checkbox" id="config-enable-token" class="sr-only peer" checked>
                  <div
                    class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-blue-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-[#1A5D8C]">
                  </div>
                </label>
              </div>
              <div class="flex items-center justify-between">
                <label class="text-sm font-medium text-gray-700">Enable Referral Code Method</label>
                <label class="relative inline-flex items-center cursor-pointer">
                  <input type="checkbox" id="config-enable-code" class="sr-only peer" checked>
                  <div
                    class="w-11 h-6 bg-gray-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-blue-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-[#1A5D8C]">
                  </div>
                </label>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Token Expiry (hours)</label>
                <input id="config-token-expiry" type="number" min="1"
                  class="w-full border border-gray-300 rounded-md px-3 py-2" placeholder="e.g., 48" value="48">
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Max Referrals Per User</label>
                <input id="config-max-referrals" type="number" min="0"
                  class="w-full border border-gray-300 rounded-md px-3 py-2" placeholder="Leave empty for unlimited">
              </div>
            </div>
          </div>
        </div>

        <!-- Save Button -->
        <div class="flex justify-end mt-6">
          <button id="saveConfigBtn"
            class="bg-[#1A5D8C] hover:bg-[#154b70] text-white font-medium px-6 py-2 rounded-md transition flex items-center gap-2">
            <i class="fas fa-save"></i> Save Configuration
          </button>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>

  <script>
    // Tab Switching
    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const tabName = btn.dataset.tab;

        // Update button styles
        document.querySelectorAll('.tab-btn').forEach(b => {
          b.classList.remove('border-[#1A5D8C]', 'text-[#1A5D8C]');
          b.classList.add('border-transparent', 'text-gray-500');
        });
        btn.classList.remove('border-transparent', 'text-gray-500');
        btn.classList.add('border-[#1A5D8C]', 'text-[#1A5D8C]');

        // Show/hide content
        document.querySelectorAll('.tab-content').forEach(content => {
          content.classList.add('hidden');
        });
        document.getElementById(`tab-${tabName}`).classList.remove('hidden');
      });
    });

    // Configure Rewards Popup
    document.getElementById('showConfigPopup').addEventListener('click', () => {
      Swal.fire({
        title: '<i class="fas fa-gift text-[#1A5D8C]"></i> Quick Reward Setup',
        html: `
        <div class="text-left space-y-4 p-2">
          <div class="border-l-4 border-[#1A5D8C] pl-3 bg-blue-50 rounded-md p-3">
            <h4 class="font-semibold text-gray-800 mb-3 flex items-center gap-2"><i class="fas fa-award text-[#1A5D8C]"></i> Reward Details</h4>
            <div class="space-y-3">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Reward Type <span class="text-red-500">*</span></label>
                <select id="swal-reward-type" class="w-full border border-gray-300 rounded-md px-3 py-2">
                  <option value="percentage">Percentage (% off)</option>
                  <option value="fixed">Fixed Amount ($ off)</option>
                </select>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Reward Value <span class="text-red-500">*</span></label>
                <input id="swal-reward-value" type="number" min="0" step="0.01" class="w-full border border-gray-300 rounded-md px-3 py-2" placeholder="e.g., 10">
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Valid for (days)</label>
                <input id="swal-reward-days" type="number" min="1" class="w-full border border-gray-300 rounded-md px-3 py-2" placeholder="e.g., 30" value="30">
              </div>
            </div>
          </div>
        </div>
      `,
        showCancelButton: true,
        confirmButtonText: '<i class="fas fa-save mr-1"></i> Save',
        cancelButtonText: '<i class="fas fa-times mr-1"></i> Cancel',
        width: '500px',
        customClass: {
          popup: 'rounded-xl shadow-2xl',
          confirmButton: 'bg-[#1A5D8C] hover:bg-[#154b70] text-white px-6 py-2 rounded-md font-medium shadow-md',
          cancelButton: 'bg-gray-200 hover:bg-gray-300 text-gray-700 px-6 py-2 rounded-md font-medium shadow-md'
        },
        preConfirm: () => {
          const type = document.getElementById('swal-reward-type').value;
          const value = parseFloat(document.getElementById('swal-reward-value').value);
          const days = parseInt(document.getElementById('swal-reward-days').value);

          if (!value || value <= 0) {
            Swal.showValidationMessage('Please enter a valid reward value');
            return false;
          }
          return { type, value, days };
        }
      }).then((result) => {
        if (result.isConfirmed) {
          saveReferralConfig(result.value);
        }
      });
    });

    // Save Configuration
    function saveReferralConfig(data) {
      Swal.fire({ title: 'Saving...', allowOutsideClick: false, didOpen: () => Swal.showLoading() });

      fetch('/admin/referral/config', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': 'Bearer ' + localStorage.getItem('token')
        },
        body: JSON.stringify(data)
      })
        .then(res => res.json())
        .then(response => {
          Swal.fire({
            icon: 'success',
            title: 'Success!',
            text: 'Configuration saved successfully!',
            timer: 2000,
            showConfirmButton: false
          });
        })
        .catch(err => {
          Swal.fire({
            icon: 'error',
            title: 'Error',
            text: err.message
          });
        });
    }

    // View Referral Details
    function viewReferralDetails(id) {
      fetch(`/admin/referral/${id}`, {
        headers: { 'Authorization': 'Bearer ' + localStorage.getItem('token') }
      })
        .then(res => res.json())
        .then(data => {
          const ref = data.data;
          Swal.fire({
            title: '<i class="fas fa-info-circle text-[#1A5D8C]"></i> Referral Details',
            html: `
          <div class="text-left space-y-3 p-3">
            <div class="grid grid-cols-2 gap-3 text-sm">
              <div class="bg-gray-50 p-3 rounded">
                <p class="text-xs text-gray-500 mb-1">Referrer</p>
                <p class="font-medium">${ref.referrer?.name || 'N/A'}</p>
                <p class="text-xs text-gray-500">${ref.referrer?.email || ''}</p>
              </div>
              <div class="bg-gray-50 p-3 rounded">
                <p class="text-xs text-gray-500 mb-1">Method</p>
                <p class="font-medium">${ref.method === 'token' ? 'Token URL' : 'Referral Code'}</p>
              </div>
              <div class="bg-gray-50 p-3 rounded">
                <p class="text-xs text-gray-500 mb-1">Referred User</p>
                <p class="font-medium">${ref.referredUser?.name || 'Pending'}</p>
                <p class="text-xs text-gray-500">${ref.referredUser?.email || ''}</p>
              </div>
              <div class="bg-gray-50 p-3 rounded">
                <p class="text-xs text-gray-500 mb-1">Reward Status</p>
                <p class="font-medium ${ref.rewardIssued ? 'text-green-600' : 'text-yellow-600'}">${ref.rewardIssued ? 'Issued' : 'Pending'}</p>
              </div>
            </div>
            ${ref.couponIssued ? `
              <div class="bg-green-50 border border-green-200 rounded-md p-3">
                <p class="text-sm font-medium text-green-800"><i class="fas fa-ticket-alt mr-1"></i> Coupon: ${ref.couponIssued}</p>
              </div>
            ` : ''}
          </div>
        `,
            confirmButtonText: 'Close',
            customClass: {
              confirmButton: 'bg-[#1A5D8C] hover:bg-[#154b70] text-white px-6 py-2 rounded-md'
            }
          });
        });
    }

    // Issue Reward
    function issueReward(id) {
      Swal.fire({
        title: 'Issue Reward?',
        text: 'This will create a coupon for the referrer.',
        icon: 'question',
        showCancelButton: true,
        confirmButtonText: 'Yes, Issue',
        confirmButtonColor: '#1A5D8C'
      }).then(result => {
        if (result.isConfirmed) {
          fetch(`/admin/referral/${id}/issue-reward`, {
            method: 'POST',
            headers: { 'Authorization': 'Bearer ' + localStorage.getItem('token') }
          })
            .then(res => res.json())
            .then(response => {
              Swal.fire('Success!', 'Reward issued successfully!', 'success').then(() => {
                location.reload();
              });
            })
            .catch(err => {
              Swal.fire('Error', err.message, 'error');
            });
        }
      });
    }

    // Save Config Button
    document.getElementById('saveConfigBtn')?.addEventListener('click', () => {
      const config = {
        rewardType: document.getElementById('config-reward-type').value,
        rewardValue: parseFloat(document.getElementById('config-reward-value').value),
        minOrder: parseFloat(document.getElementById('config-min-order').value) || 0,
        expiryDays: parseInt(document.getElementById('config-expiry-days').value),
        enableToken: document.getElementById('config-enable-token').checked,
        enableCode: document.getElementById('config-enable-code').checked,
        tokenExpiry: parseInt(document.getElementById('config-token-expiry').value),
        maxReferrals: document.getElementById('config-max-referrals').value ? parseInt(document.getElementById('config-max-referrals').value) : null
      };

      saveReferralConfig(config);
    });
  </script>

  <style>
    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: translateY(-10px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .animate-fadeIn {
      animation: fadeIn 0.4s ease-out;
    }
  </style>

  <%- include("../../views/partials/admin/footer") %>